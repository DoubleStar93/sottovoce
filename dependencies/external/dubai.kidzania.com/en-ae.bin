<script>
  //<![CDATA[
    $("#submit-contact").on('click', function(){
      $('input[type=email], input[type=text], textarea').filter('[required]').next().hide();
      $('input[type=checkbox], input[type=radio]').filter('[required]').parent().parent().next().hide();
      email = $('input#email').val();
      errorsArray = validateForm();
      if (errorsArray && errorsArray.length) {
        for(var i =0; i < errorsArray.length; i++) {
          if (errorsArray[i].type == 'checkbox' || errorsArray[i].type == 'radio') {
            $(errorsArray[i]).parent().parent().next().show();
          }
          else {
            $(errorsArray[i]).next().show();
          }
        }
      }
      else if (email && !isValidEmailAddress(email)){
        $("input#email").next().show();
      }
      else if ($('#legal_note_check').length && ($('#legal_note_check')[0].checked == false)){
        $('#legal_note_check').next().next().show()
      }
      else {
        var valuesToSubmit = $('form').serialize();
        $.ajax({
          type: $('form').attr('method'),
          url: $('form').attr('action'), //sumbits it to the given url of the form
          data: valuesToSubmit,
          dataType: "JSON" // you want a difference between normal and ajax-calls, and json is standard
        }).success(function(json){
          if (json.status == 'success') {
            contactTargetUrl = $('form').attr('contact_target_url')
            if ( contactTargetUrl && contactTargetUrl.length != 0) {
              window.location = contactTargetUrl
            }
            else {
              $('#contact-section').hide();
              $('.zanks').fadeIn();
            }
          }
          else {
             $('.captcha-error').css('display', 'block')
          }
        });
        return false;
      }
    })
    
    $('.close').click("click",function () {
      $('form').trigger("reset");
    });
    
    function validateForm() {
        var errorsArray= [];
        var requiredElements = $('input,textarea,select').filter('[required]');
        for(var i=0; i < requiredElements.length; i++) {
            if(!$(requiredElements[i]).val()) {
               errorsArray.push(requiredElements[i])
            }
            if (requiredElements[i].type == 'checkbox' && !requiredElements[i].checked) {
              errorsArray.push(requiredElements[i])
            }
            if (requiredElements[i].type == 'radio' && !$("input[name='"+requiredElements[i].name+"']:checked").val()) {
              errorsArray.push(requiredElements[i]);
            }
        }
    
        return errorsArray;
    }
    
    $("#submit-custom-contact").on('click', function(){
      $('input[type=email], input[type=text], textarea').filter('[required]').next().hide();
      $('input[type=checkbox], input[type=radio]').filter('[required]').parent().parent().next().hide();
      email = $('input#email').val();
      errorsArray = validateForm();
      if (errorsArray && errorsArray.length) {
        for(var i =0; i < errorsArray.length; i++) {
          if (errorsArray[i].type == 'checkbox' || errorsArray[i].type == 'radio') {
            $(errorsArray[i]).parent().parent().next().show();
          }
          else {
            $(errorsArray[i]).next().show();
          }
        }
      }
      else if (email && !isValidEmailAddress(email)){
        $("input#email").next().show();
      }
      else if ($('#legal_note_check').length && $('#legal_note_check')[0].checked == false){
        $('#legal_note_check').next().next().show()
      }
      else {
        var valuesToSubmit = $('form').serialize();
        $.ajax({
          type: $('form').attr('method'),
          url: $('form').attr('action'), //sumbits it to the given url of the form
          data: valuesToSubmit,
          dataType: "JSON" // you want a difference between normal and ajax-calls, and json is standard
        }).success(function(json){
          if (json.status == 'success') {
            contactTargetUrl = $('form').attr('contact_target_url')
            if ( contactTargetUrl && contactTargetUrl.length != 0) {
              window.location = contactTargetUrl
            }
            else {
              $('#contact-section').hide();
              $('.zanks').fadeIn();
            }
          } else {
             $('.captcha-error').css('display', 'block');
          }
        });
      }
      return false;
    })
    
    function isValidEmailAddress(emailAddress) {
      var pattern = /^(([^<>()\[\]\\.,;:\s@"]+(\.[^<>()\[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
      return pattern.test(emailAddress);
    };
  //]]>
</script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  function isMobile() {
    return window.matchMedia && window.matchMedia('(max-width: 768px)').matches;
  }
  function ensureTraveler() {
    var list = document.getElementById('content-list');
    if (!list) return;
    var existing = document.getElementById('mobile-traveler-panel');
    if (!isMobile()) {
      if (existing && existing.parentNode) existing.parentNode.removeChild(existing);
      return;
    }
    if (existing) return;
    var panel = document.createElement('div');
    panel.className = 'panel panel-default';
    panel.id = 'mobile-traveler-panel';
    var head = document.createElement('div');
    head.className = 'panel-heading';
    head.setAttribute('role', 'tab');
    head.style.textAlign = 'center';
    head.style.padding = '12px 0';
    var img = new Image();
    img.src = 'https://ocs.kidzania.com/traveler2.png';
    img.alt = 'Traveler';
    img.style.height = '100px';
    img.style.borderRadius = '10px';
    head.appendChild(img);
    panel.appendChild(head);
    list.appendChild(panel);
  }
  ensureTraveler();
  window.addEventListener('resize', ensureTraveler);
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function () {
  if (window.innerWidth > 1024) {
    var bar = document.querySelector('.ticket-bar');
    if (!bar) return;
    var ul = bar.querySelector('ul');
    if (!ul || bar.querySelector('img[src*="traveler2.png"]')) return;
    var img = new Image();
    img.src = 'https://ocs.kidzania.com/traveler2.png';
    img.style.height = '60px';
    img.style.position = 'absolute';
    img.style.marginLeft = '-66px';
    img.style.marginTop = '-15px';
    img.style.borderRadius = '10px';
    bar.insertBefore(img, ul);
  }
});
</script>


