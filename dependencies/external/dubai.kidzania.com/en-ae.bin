<!DOCTYPE html>
<html lang='en-AE' xmlns:fb='http://ogp.me/ns/fb#' xmlns='http://www.w3.org/1999/xhtml'>
<head>
<!-- Bootstrap -->
<style>
  /*<![CDATA[*/
    @font-face {
      font-family: "Bevan";
      src: url("/assets/Bevan.ttf");
    }
    @font-face {
      font-family: "Glyphicons Halflings";
      src: url("/assets/glyphicons-halflings-regular.eot");
      src: url("/assets/glyphicons-halflings-regular.eot?#iefix") format("embedded-opentype"),url("/assets/glyphicons-halflings-regular.woff") format("woff"),url("/assets/glyphicons-halflings-regular.ttf") format("truetype"),url("/assets/glyphicons-halflings-regular.svg#glyphicons_halflingsregular") format("svg")
    }
    @font-face {
      font-family: "FontAwesome";
      src: url("/assets/fontawesome-webfont.eot");
      src: url("/assets/fontawesome-webfont.eot?#iefix") format("embedded-opentype"),url("/assets/fontawesome-webfont.woff") format("woff"),url("/assets/fontawesome-webfont.ttf") format("truetype"),url("/assets/gfontawesome-webfont.svg#fontawesome-webfontr") format("svg")
    }
    
    @font-face {
      font-family: 'Open Sans';
      font-display: swap;
      src: url('/assets/Open_Sans/OpenSans-ExtraBold.ttf');
      font-weight: 800;
      font-style: normal, italic;
    
    }
    @font-face {
      font-family: 'Ubuntu';
      font-display: swap;
      src: url('/assets/Ubuntu/Ubuntu-Regular.ttf');
      font-weight: 400;
      font-style: normal;
    }
    @font-face {
      font-family: 'Ubuntu';
      font-display: swap;
      src: url('/assets/Ubuntu/Ubuntu-Medium.ttf');
      font-weight: 500;
      font-style: normal;
    }
    @font-face {
      font-family: 'Ubuntu';
      font-display: swap;
      src: url('/assets/Ubuntu/Ubuntu-Bold.ttf');
      font-weight: 700;
      font-style: normal;
    }
    @font-face {
      font-family: 'Ubuntu';
      font-display: swap;
      src: url('/assets/Ubuntu/Ubuntu-LightItalic.ttf');
      font-weight: 200;
      font-style: italic;
    }
    @font-face {
      font-family: 'Ubuntu';
      font-display: swap;
      src: url('/assets/Ubuntu/Ubuntu-BoldItalic.ttf');
      font-weight: 700;
      font-style: italic;
    }
    @font-face {
      font-family: 'Kanit';
      src: url('/assets/Kanit/Kanit-Regular.ttf');
      font-weight: 400;
      font-style: normal;
    
    }
    @font-face {
      font-family: 'Kanit';
      src: url('/assets/Kanit/Kanit-Italic.ttf');
      font-weight: 400;
      font-style: italic;
    
    }
    
    @font-face {
      font-family: 'Kanit';
      src: url('/assets/Kanit/Kanit-Bold.ttf');
      font-weight: 700;
      font-style: normal;
    
    }
    @font-face {
      font-family: 'Kanit';
      src: url('/assets/Kanit/Kanit-BoldItalic.ttf');
      font-weight: 700;
      font-style: italic;
    }
    
    @font-face {
      font-family: 'Kanit';
      src: url('/assets/Kanit/Kanit-ExtraBold.ttf');
      font-weight: 800;
      font-style: normal;
    }
    
    @font-face {
      font-family: 'Kanit';
      src: url('/assets/Kanit/Kanit-ExtraBoldItalic.ttf');
      font-weight: 800;
      font-style: italic;
    
    }
    
    @font-face {
      font-family: 'Cairo';
      src: url('/assets/Cairo/Cairo-Regular.ttf');
      font-weight: 400;
      font-style: normal;
    
    }
    @font-face {
      font-family: 'Cairo';
      src: url('/assets/Cairo/Cairo-Bold.ttf');
      font-weight: 600;
      font-style: normal;
    
    }
    @font-face {
      font-family: 'Cairo';
      src: url('/assets/Cairo/Cairo-Black.ttf');
      font-weight: 900;
      font-style: normal;
    
    }
    /* ======== CUSTOM FONT ==========*/
    @font-face {
      font-family: 'icomoon';
      src:  url('/assets/icomoon.eot?cj2tex');
      src:  url('/assets/icomoon.eot?cj2tex#iefix') format('embedded-opentype'),
        url('/assets/icomoon.ttf?cj2tex') format('truetype'),
        url('/assets/icomoon.woff?cj2tex') format('woff'),
        url('/assets/icomoon.svg?cj2tex#icomoon') format('svg');
      font-weight: normal;
      font-style: normal;
    }
    
    /* ======== BOOTSTRAP STYLE ========= */
    ul {
      list-style: disc url('/assets/list-bullet.svg');
    }
    
    /* ======= KidZania font =========== */
    @font-face {
        font-family: 'KZfont';
        src: url('/assets/kz-font.ttf');
        src:  url('/assets/kz-font.eot') format('embedded-opentype'),
          url('/assets/kz-font.ttf') format('truetype'),
          url('/assets/kz-font.woff') format('woff'),
          url('/assets/kz-font.svg') format('svg');
        font-weight: 400;
        font-style: normal;
    }
    
    /* ======== Bar Code ================ */
    @font-face {
      font-family: 'barcode';
      src: url('/assets/barcode.woff') ;
      font-weight: 400;
      font-style: normal;
    }
  /*]]>*/
</style>

