    $( document ).ready(function() {  
        //COOKIE BAR
        $('#cookiesOk').click(function(){
            $('.cookie-message').css('opacity','0');
            $('.cookie-message').css('visibility','hidden');
            Cookies.set('visited','yes', {expires : 365});
