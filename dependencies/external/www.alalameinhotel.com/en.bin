<script>
  $(window).on("load", function() {
    var vid = document.getElementById("hero-vid");
    vid.onloadeddata = function() {
      // console.clear();
      vid.play();
    };
  });
  $(document).ready(function() {
    if ($('.wp-block-address-image-box-6.is-selected').length <= 1) {
      $('.flickity-button').addClass('d-none');
    }
  });

  jQuery(document).ready(function($) {
    $('.close-msg').click(function() {
      $('.important-msg').removeClass('d-flex').hide();
      $('#navbar__Global').css('top', '0');
      $('.fullscreen-hero-banner-booking-widget').css('margin-top', '0');
    });

    function calculateTop() {
      var correction = 0;
      if (window.matchMedia('(min-width:767px) and (max-width: 992px)') && ICL == 'en') {
        $('#navbar__Global').css('top', $('.important-msg').innerHeight());
        $('.fullscreen-hero-banner-booking-widget').css('margin-top', $('.important-msg').innerHeight());
      }
      if (window.matchMedia("(max-width: 600px)") && ICL == 'en') {
        $('#navbar__Global').css('top', $('.important-msg').innerHeight() - 20);
        $('.fullscreen-hero-banner-booking-widget').css('margin-top', $('.important-msg').innerHeight() - 20);
      }
      if (window.matchMedia("(min-width: 1024px)")) {
        $('#navbar__Global').css('top', $('.important-msg').innerHeight());
        $('.fullscreen-hero-banner-booking-widget').css('margin-top', $('.important-msg').innerHeight());
      }
    }

    $(window).on('resize', function() {
      calculateTop();
    });

    // Call calculateTop initially
    calculateTop();
  });
</script><!-- Rocket has webp -->
