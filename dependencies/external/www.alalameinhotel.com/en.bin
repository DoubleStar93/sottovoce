<!-- The Booking Modal -->
<div class="modal fade bookingmodal booking-modal-hotel p-0" id="bookingModal">
  <div class="modal-dialog ">

    <div class="modal-content pt-0">
      <!-- Modal Header -->
      <div class="modal-header pl-0 pr-0">
