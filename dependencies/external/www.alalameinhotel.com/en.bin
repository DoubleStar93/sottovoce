            alt="Al Alamein Hotels"></a>

        <button type="button" class="close" data-dismiss="modal" id="modelclosesign"><i
            class="fal fa-times"></i></button>
      </div>
      <!-- Modal body -->
      <div class="modal-body">
        <div class="container pt-3 pt-lg-0  mb-0 pl-0 pr-0">
          <h2 class="bookingmodaltitle pb-3 pb-lg-0 display-2-48">Select your check-in & check-out dates</h2>
          <hr class="my-3">
          <p class="py-2 hotel_name"><i class="fal fa-map-marker-alt pr-2 pl-1"></i>Al Alamein Hotel</p>
          <div class="row  justify-content-center  h-100  bookboxedit block">
