	        <style>
			.nav-indentation-class {
				padding: 10px 0px;
				margin: 0 40px 0 15px;
				border-bottom: 1px solid rgba(0, 0, 0, .1);
			} 
		</style>
          


	<style>
		.nav-indentation-class>.nav-link {
			font-weight: 700 !important;
		}

