",\"clearFilter\":\"Clear Filter\",\"subtotal\":\"Subtotal\",\"continue\":\"Continue\",\"roomNumber\":\"Room {number}\",\"selectMoreRooms\":\"Select {count} more room(s) to continue\",\"people\":\"People\",\"virtualTour\":\"Virtual Tour\",\"floorPlan\":\"Floor Plan\",\"viewMore\":\"View More\",\"roomAmenities\":\"Room Amenities\",\"details\":\"Details\",\"seeMoreOption\":\"See more option\",\"bookRoom\":\"Book Room\",\"perNight\":\"per night\",\"fromPrice\":\"From {price}\",\"selectARate\":\"Select a Rate\",\"allRoomsSelected\":\"All rooms selected\",\"promotionTerms\":\"Promotion Terms \u0026 Conditions\",\"guaranteePolicy\":\"Guarantee Policy\",\"cancellationPolicy\":\"Cancellation Policy\",\"freeUntil\":\"Free until {date}\",\"hotel\":\"Hotel\",\"checkInLabel\":\"Check-in\",\"checkOutLabel\":\"Check-out\",\"roomsLabel\":\"Rooms\",\"codeLabel\":\"Code\",\"upgradeRoomQuestion\":\"Would you like to upgrade your room?\",\"upgradeRoomQuestionMulti\":\"Would you like to upgrade your {roomName}?\",\"upgradeRoom\":\"Upgrade Room\",\"upgradeRoomNote\":\"Payment of this additional amount is required for room upgrade.\",\"addAddOnsFor\":\"Add add-ons for {roomName}\",\"addOnsForRoom\":\"Add-ons for {roomName}\",\"loadingServices\":\"Loading available services...\",\"noServicesAvailable\":\"No add-on services available for this room type.\",\"perStay\":\"per stay\",\"perPersonPerNight\":\"per person / night\",\"perPerson\":\"per person\",\"selectNightsLabel\":\"Select nights\",\"selectedOfTotal\":\"{current} of {total} selected\",\"deselectAll\":\"Deselect all\",\"selectAllNights\":\"Select all nights\",\"persons\":\"Persons\",\"ofMax\":\"of {max}\",\"savingAddOns\":\"Saving add-ons...\",\"skipAddOns\":\"Skip Add-ons\",\"continueToGuestInfo\":\"Continue to Guest Info\",\"selectNextRoom\":\"Select Next Room\",\"serviceAlreadySelected\":\"Service Already Selected\",\"serviceAlreadyAddedFor\":\"You have already added {service} for your {room}.\",\"addServiceAgainConfirm\":\"Are you sure you want to add this service again?\",\"yesAddAgain\":\"Yes, Add Again\",\"sessionExpired\":\"Session Expired\",\"sessionExpiredMessage\":\"Your reservation hold has expired. Room availability and pricing may have changed. Please start a new search.\",\"returnToHome\":\"Return to Home\",\"reservationHeldFor\":\"Reservation held for\",\"person\":\"person\",\"titleLabel\":\"Title\",\"phoneCode\":\"Code\",\"selectCountry\":\"Select country\",\"specialRequestsPlaceholder\":\"Any special requests or preferences...\",\"creditCardGuarantee\":\"Credit Card Guarantee\",\"creditCardGuaranteeNote\":\"A valid credit card is required to guarantee your reservation. No charge will be made at this time unless stated in the cancellation policy.\",\"prepaidNote\":\"Your card will be charged the full amount to confirm this non-refundable booking.\",\"paymentEarlyBird\":\"Payment — Early Bird Rate (charged immediately)\",\"paymentAdvancePurchase\":\"Payment — Advance Purchase (charged immediately)\",\"paymentPrepaid\":\"Payment — Prepaid Rate (charged immediately)\",\"cardholderName\":\"Cardholder Name\",\"cardholderNameHint\":\"As it appears on the card\",\"cardNumber\":\"Card Number\",\"expiryDate\":\"Expiry Date\",\"cvv\":\"CVV\",\"completePayment\":\"Complete Payment\",\"loadingPaymentGateway\":\"Loading payment gateway...\",\"paymentFailed\":\"Payment Failed\",\"closeAndTryAgain\":\"Close \u0026 Try Again\",\"restartBooking\":\"Restart Booking\",\"completingReservation\":\"Completing your reservation...\",\"pleaseDoNotClose\":\"Please do not close this page.\",\"paymentSecureNote\":\"Your payment is processed securely by Emaar ePay.\",\"updateSearch\":\"Update Search\",\"selectCheckOut\":\"Select check-out date\",\"done\":\"Done\",\"privacyPolicy\":\"Privacy Policy\"},\"offers\":{\"Home\":\"Home\",\"title\":\"Offers\",\"allOffers\":\"All Offers\",\"memberOnly\":\"Members Only\",\"terms\u0026ConditionsTitle\":\"Terms and Conditions\",\"termsConditions\":\"Terms \u0026 Conditions Apply\",\"validUntil\":\"Valid Until\",\"validFrom\":\"From\",\"validOn\":\"Valid On\",\"bookOffer\":\"Book Offer\",\"categories\":{\"all\":\"All\",\"stay\":\"Stay\",\"dine\":\"Dine\",\"spa\":\"Spa\"},\"relatedOffers\":\"Related Offers\",\"viewOurOffers\":\"View Our Offers\",\"ongoing\":\"Ongoing\",\"promoCode\":\"Promo Code:\",\"backToOffers\":\"Back to Offers\",\"backToOffer\":\"Back to Offer\"},\"blog\":{\"title\":\"Blog\",\"heroSubtitle\":\"Stories and insights from the world of Armani Hotels\",\"readMore\":\"Read More\",\"relatedPosts\":\"Related Posts\",\"categories\":\"Categories\",\"categoriesAll\":\"All\",\"categoriesNews\":\"News\",\"categoriesExperiences\":\"Experiences\",\"categoriesDining\":\"Dining\",\"categoriesWellness\":\"Wellness\",\"recentPosts\":\"Recent Posts\",\"author\":\"Author\",\"excerpt\":\"Excerpt\",\"prevPage\":\"Previous\",\"nextPage\":\"Next\",\"page\":\"Page\"},\"media\":{\"title\":\"Media Center\",\"photos\":\"Photos\",\"videos\":\"Videos\",\"awards\":\"Awards\",\"press\":\"Press\",\"pressReleases\":\"Press Releases\",\"lightbox\":\"View full size\",\"underDevelopment\":\"This section is under development.\"},\"auth\":{\"signIn\":\"Sign In\",\"signUp\":\"Sign Up\",\"signOut\":\"Sign Out\",\"email\":\"Email\",\"password\":\"Password\",\"confirmPassword\":\"Confirm Password\",\"firstName\":\"First Name\",\"lastName\":\"Last Name\",\"phone\":\"Phone\",\"country\":\"Country\",\"forgotPassword\":\"Forgot password?\",\"resetPassword\":\"Reset Password\",\"changePassword\":\"Change Password\",\"myDashboard\":\"My Dashboard\",\"personalDetails\":\"Personal Details\",\"myBookings\":\"My Bookings\",\"memberSince\":\"Member since\",\"memberNumber\":\"Member Number\",\"noAccount\":\"Don't have an account?\",\"alreadyHaveAccount\":\"Already have an account?\",\"createAccount\":\"Create Account\",\"acceptTerms\":\"I accept the terms and conditions\",\"iAcceptThe\":\"I accept the\",\"termsAndConditions\":\"Terms and Conditions\",\"welcome\":\"Welcome\"},\"manageBooking\":{\"title\":\"Retrieve Your Booking\",\"heroTitle\":\"Manage Booking\",\"breadcrumbHome\":\"Home\",\"breadcrumbManageBooking\":\"Manage Booking\",\"tabStay\":\"Stay\",\"tabDine\":\"Dine\",\"tabManage\":\"Manage your reservation\",\"tabCancel\":\"Cancel your reservation\",\"tabInvoice\":\"Request an invoice\",\"formDescriptionStay\":\"Complete the below form to review, modify or cancel your booking. All fields required.\",\"formDescriptionDine\":\"After completing this form, your reservation will display so you can review, modify, or cancel. All fields required.\",\"formDescription\":\"Complete the below form to review, modify or cancel your booking. All fields required.\",\"formDescriptionCancel\":\"Complete the below form to cancel your booking. All fields required.\",\"formDescriptionInvoice\":\"Complete the below form to request an invoice for your booking. All fields required.\",\"selectHotel\":\"Select a Hotel\",\"selectRestaurant\":\"Select a Restaurant\",\"confirmationNumber\":\"Confirmation Number\",\"lastName\":\"Last Name\",\"search\":\"Search\",\"searching\":\"Searching...\",\"invalidDetails\":\"Invalid Details\",\"invalidDetailsDescription\":\"Please re-enter your booking details. If this reservation was made on a third-party booking site, contact them directly to make changes.\",\"hotelDubai\":\"Armani Hotel Dubai, Burj Khalifa\",\"hotelMilano\":\"Armani Hotel Milano\",\"bookingReference\":\"Booking Reference\",\"email\":\"Email\",\"findBooking\":\"Find Booking\",\"bookingDetails\":\"Booking Details\",\"roomType\":\"Room Type\",\"guestCount\":\"Guests\",\"duration\":\"Duration\",\"guestName\":\"Guest Name\",\"phone\":\"Phone\",\"country\":\"Country\",\"payment\":\"Payment\",\"cancellationPolicy\":\"Cancellation Policy\",\"searchAgain\":\"Search Again\",\"modify\":\"Modify\",\"cancel\":\"Cancel\",\"noBookingFound\":\"No booking found\",\"tryAgain\":\"Try again with different details\",\"signInToView\":\"Sign In to view your booking\"},\"footer\":{\"newsletter\":\"Newsletter\",\"newsletterText\":\"Subscribe to our newsletter for exclusive offers and the latest news\",\"emailPlaceholder\":\"Enter your email\",\"subscribe\":\"Subscribe\",\"followUs\":\"Follow Us\",\"followGiorgio\":\"Follow Giorgio Armani\",\"followEmporio\":\"Follow Emporio Armani\",\"termsOfUse\":\"Terms of Use\",\"privacyPolicy\":\"Privacy Policy\",\"cookiePolicy\":\"Cookie Policy\",\"cookieSettings\":\"Cookie Settings\",\"sitemap\":\"Sitemap\",\"allRightsReserved\":\"All Rights Reserved\",\"copyright\":\"© {year} Armani Hotels \u0026 Resorts\",\"uaePhone\":\"UAE: 800 ARMANI\",\"ksaPhone\":\"KSA: 8008971961\",\"milanPhone\":\"Milano: +39 02 8883 8888\",\"stay\":\"Stay\",\"offers\":\"Offers\",\"dine\":\"Dining\",\"wellness\":\"Wellness\",\"events\":\"Events\",\"armaniExperience\":\"Armani Experience\",\"timeOut\":\"Time Out\",\"tour360\":\"360° Tour\",\"hotelGlossary\":\"Hotel Glossary\",\"aboutUs\":\"About Us\",\"contactUs\":\"Contact Us\",\"careers\":\"Careers\",\"manageBooking\":\"Manage Booking\",\"uByEmaar\":\"U by Emaar\",\"legalDisclaimer\":\"Legal Disclaimer\",\"termsConditions\":\"Terms \u0026 Conditions\",\"whistleblowing\":\"Whistleblowing\",\"rightsReservedDubai\":\"Rights reserved to Armani Hotel Dubai\",\"rightsReservedMilano\":\"Rights reserved to Armani Hotel Milano\",\"rightsReservedGlobal\":\"© Rights reserved to Armani Hotels \u0026 Resorts\",\"tel\":\"Tel\",\"email\":\"Email\",\"chatWithUs\":\"Chat with us\",\"hotelsAndResorts\":\"Hotels \u0026 Resorts\",\"armaniHotelDubai\":\"Armani Hotel Dubai\",\"armaniHotelMilano\":\"Armani Hotel Milano\",\"mediaCenter\":\"Media Center\"},\"contact\":{\"title\":\"Contact Us\",\"name\":\"Name\",\"firstName\":\"First Name\",\"lastName\":\"Last Name\",\"email\":\"Email\",\"phone\":\"Phone\",\"mobile\":\"Mobile Phone\",\"country\":\"Country\",\"city\":\"City\",\"message\":\"Message\",\"enquiry\":\"Tell us about your enquiry (Optional)\",\"subject\":\"Subject\",\"selectSubject\":\"Select Subject\",\"subjectFeedback\":\"Feedback\",\"subjectInquiry\":\"Inquiry\",\"subjectCallback\":\"Callback Request\",\"subjectOther\":\"Other\",\"send\":\"Subscribe\",\"address\":\"Address\",\"requestForProposal\":\"Request for Proposal\",\"general\":\"General Enquiries\",\"generalDesc\":\"For general questions and information\",\"restaurantReservations\":\"Restaurant Reservations\",\"restaurantReservationsDesc\":\"Reserve a table at our restaurants\",\"events\":\"Events \u0026 Catering\",\"eventsDesc\":\"Plan your next event with us\",\"formTitle\":\"Have a Question?\",\"formSubtitle\":\"Fill out the form below and we will get in touch with you\",\"hotelReservation\":\"Hotel Reservation\",\"hotelReservationDesc\":\"For further information, bookings, or special requests, we invite you to get in touch\",\"dineReservation\":\"Book Your Dine Experience\",\"spaReservation\":\"Book Your Spa Treatment\",\"tollFreeNumbers\":\"Toll Free Numbers\",\"contactDepartments\":\"Contact Us\",\"sales\":\"Sales\",\"marketing\":\"Marketing\",\"humanResources\":\"Human Resources\",\"eventsDept\":\"Events\",\"weAreHere\":\"We Are Here\",\"ourLocations\":\"Our Locations\",\"privacyMarketing\":\"I agree for my data to be processed in line with the \u003cprivacyLink\u003ePrivacy Policy\u003c/privacyLink\u003e in order for you to send me marketing and promotional content.\",\"privacyThirdParty\":\"I agree for my data to be processed in line with the \u003cprivacyLink\u003ePrivacy Policy\u003c/privacyLink\u003e to enable communication to third parties.\",\"subscribeLabel\":\"Sign up to receive exclusive offers and news from Armani Hotels \u0026 Resorts\",\"successMessage\":\"Thank you for your message. We will get back to you shortly.\",\"successBanner\":\"Thank you for contacting us. Our team will review your enquiry and get back to you shortly.\",\"errorMessage\":\"An error occurred. Please try again.\",\"networkError\":\"Network error. Please check your connection and try again.\",\"required\":\"required\",\"requiredNote\":\"\\\"*\\\" indicates required fields\",\"genericNumber\":\"Generic Number\",\"roomReservations\":\"Room Reservations\",\"restaurantReservationsPhone\":\"Restaurant Reservations\",\"eventEnquiries\":\"Event Enquiries\",\"armaniRetail\":\"Armani Retail\",\"chatWithUs\":\"Chat with us\",\"sending\":\"Sending…\",\"submitRequest\":\"Submit Request\",\"countryCode\":\"Country Code\",\"firstNameRequired\":\"First name is required.\",\"firstNameTooShort\":\"First name must be at least 2 characters.\",\"lastNameRequired\":\"Last name is required.\",\"lastNameTooShort\":\"Last name must be at least 2 characters.\",\"emailRequired\":\"Email is required.\",\"emailInvalid\":\"Please enter a valid email address.\",\"mobileInvalid\":\"Please enter a valid phone number.\",\"subjectRequired\":\"Please select a subject.\",\"privacyMarketingRequired\":\"You must agree to the marketing privacy policy.\",\"privacyThirdPartyRequired\":\"You must agree to the third-party privacy policy.\"},\"errors\":{\"notFound\":\"Page Not Found\",\"notFoundMessage\":\"The page you are looking for does not exist.\",\"notFoundHint\":\"The URL may be incorrect or the page may have been moved. Use the links below to get back on track.\",\"serverError\":\"Server Error\",\"serverErrorMessage\":\"Something went wrong. Please try again later.\",\"goHome\":\"Go to Home\",\"tryAgain\":\"Try Again\",\"backToHome\":\"Back to Home\",\"bookingError\":\"Booking Error\",\"bookingErrorMessage\":\"Your booking was not completed. Payment was not charged. Please try again or contact reservations.\",\"backToSearch\":\"Back to Search\",\"viewSitemap\":\"View sitemap\",\"whereToGo\":\"Where to go\",\"needHelpNow\":\"Need help now?\",\"contactHelpDesk\":\"Contact our 24x7 customer help desk\",\"notFoundFunnyPhrase\":\"Even the best-dressed take a wrong turn sometimes.\"},\"dining\":{\"dine\":\"DINE\",\"heroTitle\":\"DINE WITH ARMANI\",\"heroSubtitle\":\"At the Armani Hotel Dubai, located in the stunning Burj Khalifa, dining is an art form. The Armani Hotel showcases exquisite restaurants such as Armani/Ristorante for Italian cuisine and Armani/Amal for Indian flavours. Each dining venue at the Armani Hotel is crafted to offer a unique and luxurious experience, with spectacular views of the Dubai Fountain and Burj Lake, setting it apart from other hotels in Burj Khalifa and Dubai in general. Immerse yourself in the ultimate culinary adventure at the Armani Hotel Dubai.\",\"heroSubtitleMilano\":\"Experience exquisite dining at Armani Hotel Milano, where Italian culinary traditions meet contemporary innovation in an atmosphere of refined elegance.\",\"restaurants\":\"Our Restaurants\",\"reserve\":\"Reserve\",\"discoverMore\":\"Discover More\",\"featuredOffers\":\"Featured Offers\",\"multipleLocation\":\"Multiple Location\",\"faqs\":\"FAQs\",\"openingHours\":\"Opening Hours\",\"closed\":\"Closed\",\"cuisine\":\"Cuisine\",\"moreDining\":\"More Dining Options\",\"restaurantNotFound\":\"Restaurant Not Found\",\"dressCode\":\"Dress Code\",\"location\":\"Location\",\"description\":\"Description\",\"menu\":\"Menu\",\"reserveTable\":\"Reserve a Table\",\"gallery\":\"Gallery\",\"overview\":\"Overview\",\"photoGallery\":\"Photo Gallery\",\"contactInfoLocation\":\"Contact Info \u0026 Location\",\"viewMenu\":\"View Menu\",\"email\":\"Email\",\"phone\":\"Phone\",\"address\":\"Address\",\"reservation\":{\"title\":\"Reserve a Table\",\"restaurant\":\"Restaurant\",\"date\":\"Date\",\"time\":\"Time\",\"partySize\":\"Party Size\",\"guestName\":\"Guest Name\",\"email\":\"Email\",\"submit\":\"Submit Reservation\"}},\"wellness\":{\"heroTitle\":\"Wellness\",\"heroSubtitle\":\"Rejuvenate body and mind in our sanctuaries of calm\",\"spa\":\"Spa\",\"pool\":\"Pool\",\"fitness\":\"Fitness\",\"spaOverview\":\"Armani/SPA offers bespoke treatments designed to nourish and revitalise. Our therapists combine ancient techniques with contemporary wellness practices.\",\"treatments\":\"Treatments\",\"treatmentsTitle\":\"Wellness Treat\",\"bookTreatment\":\"Book a Treatment\",\"requestTreatment\":\"Request a Treatment\",\"spaRequestTitle\":\"Book Your Spa Experience\",\"spaRequestDesc\":\"Fill out the form below and our team will get in touch with you to confirm your appointment.\",\"poolOverview\":\"Our infinity pool offers panoramic views and a serene environment for relaxation.\",\"poolHours\":\"Pool Hours\",\"fitnessOverview\":\"Our state-of-the-art fitness centre is equipped with the latest equipment for your wellness journey.\",\"facilities\":\"Facilities\",\"gallery\":\"Gallery\",\"faqs\":\"FAQs\",\"featuredOffers\":\"Featured Offers\",\"heroSubtitleMilano\":\"A sanctuary of calm in the heart of Milan's fashion district.\"},\"spaRequest\":{\"title\":\"Spa Request Form\",\"requiredNote\":\"\\\"*\\\" indicates required fields\",\"intro\":\"Fill out the form below and we will get in touch with you\",\"treatment\":\"Treatment\",\"selectTreatment\":\"Select treatment type\",\"preferredTherapist\":\"Preferred Therapist\",\"preferredDate\":\"Preferred Date\",\"preferredTime\":\"Preferred Time\",\"selectTime\":\"Preferred Time\",\"firstName\":\"First Name\",\"lastName\":\"Last Name\",\"phoneCode\":\"Code\",\"phone\":\"Mobile Phone\",\"country\":\"Country\",\"city\":\"City\",\"email\":\"Email\",\"enquiry\":\"Tell us about your enquiry (Optional)\",\"marketingConsent\":\"I agree for my data to be processed in line with the Privacy Policy in order for you to send me marketing and promotional content.\",\"thirdPartyConsent\":\"I agree for my data to be processed in line with the Privacy Policy to enable communication to third parties.\",\"subscribe\":\"Sign up to receive exclusive offers and news from Armani Hotels \u0026 Resorts\",\"submit\":\"Submit\",\"submitting\":\"Submitting...\",\"successMessage\":\"Thank you for your spa request. We will contact you shortly to confirm your appointment.\",\"errorGeneric\":\"An error occurred. Please try again.\",\"errorNetwork\":\"Network error. Please check your connection and try again.\",\"contactInfo\":\"Direct Contact\",\"tel\":\"Tel\",\"email2\":\"Email\",\"validation\":{\"treatmentRequired\":\"Please select a treatment type\",\"firstNameRequired\":\"First name is required\",\"firstNameTooShort\":\"First name must be at least 2 characters\",\"lastNameRequired\":\"Last name is required\",\"lastNameTooShort\":\"Last name must be at least 2 characters\",\"emailRequired\":\"Email address is required\",\"emailInvalid\":\"Please enter a valid email address\",\"phoneRequired\":\"Phone number is required\",\"phoneInvalid\":\"Please enter a valid phone number (digits only)\",\"dateRequired\":\"Please select a preferred date\",\"datePast\":\"Selected date cannot be in the past\",\"timeRequired\":\"Please select a preferred time\",\"nameInvalid\":\"Only letters, spaces, hyphens and apostrophes are allowed\",\"marketingConsentRequired\":\"You must agree to the marketing privacy policy.\",\"thirdPartyConsentRequired\":\"You must agree to the third-party privacy policy.\"}},\"terms\":{\"title\":\"Terms \u0026 Conditions\",\"intro\":\"Please read these Terms \u0026 Conditions carefully. These are the general Terms \u0026 Conditions governing your access and use of this website (\\\"Site\\\"). This website is owned and operated by Emaar Properties PJSC. By using the Website or by clicking to accept the Terms of Use when available, you accept and agree to be bound by these Terms of Use and our Privacy Policy. If you do not want to agree, you must not access or use the Website.\",\"section1Title\":\"Changes to the terms of use\",\"section1Content\":\"We may revise and update these Terms of Use from time to time. All changes are effective immediately when we post them. Your continued use of the Website following the posting of revised Terms of Use means that you accept the changes. You are expected to check this page from time to time so you are aware of any changes.\",\"section2Title\":\"Intellectual property rights\",\"section2Content\":\"The Website and its entire contents, features and functionality are owned by the Company, its licensors or other providers and are protected by United Arab Emirates and international copyright, trademark and other intellectual property laws. These Terms permit you to use the Website for your personal, non-commercial use only. You must not reproduce, distribute, modify, or publicly display any of the material on our Website except as permitted.\",\"section3Title\":\"Reliance on information posted\",\"section3Content\":\"The information presented on or through the Website is made available solely for general information purposes. We do not warrant the accuracy, completeness or usefulness of this information. Any reliance you place on such information is strictly at your own risk. We disclaim all liability arising from any reliance placed on such materials.\",\"section4Title\":\"Information about you\",\"section4Content\":\"All information we collect on this Website is subject to our Privacy Policy. By using the Website, you consent to all actions taken by us with respect to your information in compliance with the Privacy Policy.\",\"contactTitle\":\"Contact\",\"contactText\":\"For questions about these Terms of Use, please contact us at\"},\"privacy\":{\"title\":\"Privacy Policy\",\"intro\":\"We take your privacy seriously and are committed to safeguarding your personal information. Emaar Hospitality Group LLC (\\\"Company\\\", \\\"we\\\" or \\\"us\\\") values you as our guest and is committed to protecting your privacy through our compliance with this policy. This policy describes the sources of your personal data that we may collect and our practices for collecting, using, maintaining, protecting and disclosing that information. Please read this policy carefully. By accessing or using our platforms, you agree to this privacy policy.\",\"section1Title\":\"What information we collect about you\",\"section1Content\":\"The information we collect may include: information you provide in forms (e.g. when registering, subscribing, using contact or enquiry forms, or requesting services), including name, email, phone number, nationality, address, identification, and payment details; records of your correspondence; and details of transactions you carry out through our Website.\",\"section2Title\":\"Other information we collect\",\"section2Content\":\"We may automatically collect details of your visits to our Website (traffic data, location data, logs, resources you access), usage details, browser types, operating system, IP addresses, and information collected through cookies, web beacons and other tracking technologies. This helps us improve our Website and deliver a better, more personalised service.\",\"section3Title\":\"Why we collect and how we use your information\",\"section3Content\":\"We use personal information to facilitate reservations and bookings, manage loyalty programmes (e.g. U BY EMAAR), respond to your queries, send you information about our services and offers (you may opt out), personalise your experience, enable benefits from business partners, request feedback and respond to complaints, and for other legitimate business purposes as described in the full policy.\",\"section4Title\":\"How to contact us\",\"section4Content\":\"If you have any questions or concerns about this privacy policy or your personal information, please contact us using the details provided in the contact section below.\",\"contactTitle\":\"Contact\",\"contactText\":\"For privacy-related enquiries, please contact us at\"},\"sitemap\":{\"title\":\"Sitemap\",\"content\":\"Find your way around our website. Below are the main sections and pages available.\",\"sectionCorporate\":\"Armani Hotels \u0026 Resorts\",\"sectionHotels\":\"Hotels\",\"sectionRestaurants\":\"Restaurants\",\"sectionTimeouts\":\"Timeouts\",\"sectionBlogs\":\"Blogs\",\"hotelDubai\":\"Armani Hotel Dubai\",\"hotelMilano\":\"Armani Hotel Milano\",\"aboutUs\":\"About Us\",\"contactUs\":\"Contact Us\",\"uByEmaar\":\"U By Emaar\",\"mediaCenter\":\"Media Center\",\"legalDisclaimer\":\"Legal Disclaimer\",\"privacyPolicy\":\"Privacy Policy\",\"cookiePolicy\":\"Cookie Policy\",\"termsAndConditions\":\"Terms and Conditions\",\"careers\":\"Careers\",\"stay\":\"Stay\",\"dine\":\"Dine\",\"wellness\":\"Wellness\",\"events\":\"Events\",\"offers\":\"Offers\",\"armaniExperience\":\"Armani Experience\",\"timeout\":\"Timeout\"},\"cookiePolicy\":{\"title\":\"Cookie Policy\",\"description\":\"How Emaar Hotels \u0026 Resorts uses cookies on our websites.\",\"intro\":\"This Cookie Policy sets out the basis on which we, Emaar Hotels \u0026 Resorts (Dubai), use cookies and similar technologies on or in relation to our websites. This Cookie Policy is effective from 30 Oct 2019.\",\"section1Title\":\"What are Cookies and Other Tracking Technologies?\",\"section1Cookies\":\"Cookies: Cookies are small text files which a website may put on your computer or mobile device when you visit a site or page. The other tracking technologies work similarly to cookies and place small data files on your devices or monitor your website activity to enable us to collect information about how you use our Sites. This allows our Sites to recognize your device from those of other users of the Sites. Emaar may use this data to analyse trends and statistics, use cookie data for re-targeting activities, and to help us provide a better customer service.\",\"section1Flash\":\"Flash Cookies: Certain features of our Website may use local stored objects (or Flash cookies) to collect and store information about your preferences and navigation to, from and on our Website. Flash cookies are not managed by the same browser settings as are used for browser cookies.\",\"section1Beacons\":\"Web Beacons: Pages of the Website and our emails may contain small electronic files known as web beacons (also referred to as clear gifs, pixel tags and single-pixel gifs) that permit us, for example, to count users who have visited those pages or opened an email and for other related website statistics (for example, recording the popularity of certain website content and verifying system and server integrity).\",\"section2Title\":\"What information we collect using Cookies and Other tracking Technologies?\",\"section2Content\":\"We may collect information that does not directly reveal your specific identity or does not directly relate to you as an individual. We may automatically collect the following information when you use our service: Your device, browsing actions and patterns collected automatically as you navigate through our websites. Usage details, time of requests, Browser types, operating system, IP addresses and information collected through cookies, web beacons and other tracking technologies. Details of your visits to our Website, including traffic data, location data, logs and other communication data and the resources that you access and use on the Website. Information about your computer and internet connection, operating system and browser type.\",\"section3Title\":\"How do our Sites use Cookies and Other Tracking Technologies?\",\"section3Content\":\"Emaar uses cookies and other tracking technologies across its websites to improve their performance and enhance your user experience. At times we may seek to place a cookie on your device (for instance, your computer's browsers) which allows the server to recognise the device when it visits again, to track statistical information about navigation to and throughout certain areas of our website, and to Emaar promotions on other websites. The information that is tracked by such a cookie is used only for internal purposes, such as to improve website navigation and to measure the effectiveness of our promotional placements. For example, we keep track of the domains from which people visit and we also measure visitor activity on the website, but in a manner that would keep the information anonymous.\",\"section4Title\":\"Do we use any Cookies from third-party Companies?\",\"section4Content\":\"To administer our Sites and for research purposes, Emaar also has contracted with third-party service providers to track and analyse statistical usage and volume information from our Site users. These third-party service providers use persistent Cookies to help us to improve the user experience, manage our Site content, and analyse how users navigate and utilize the Sites.\",\"section5Title\":\"What types of cookies are there, and which ones are used on the site?\",\"section5Link\":\"Please click here for information about cookies on our website.\",\"section5CookieInfoUrl\":\"https://www.armanihotels.com/en/cookie-info/\",\"section5Content\":\"We maintain the highest levels of confidentiality for this information. This anonymous information is used and analysed only at an aggregate level to help us understand trends and patterns. If you do not want your transaction details used in this manner, you can either disable your cookies by following the instructions set out in \\\"How to enable and disable cookies using your browser\\\" section below. However, if you prefer not to accept cookies, you can set your browser to reject them or to alert you before one is placed. If you have any questions now or during your visit, please contact us using the contact section below.\",\"section6Title\":\"How to enable and disable cookies using your browser:\",\"section6Content\":\"There are several different ways in which you can accept or reject some or all cookies. Some of the main methods of doing so are described below. You are welcome to block the use of some or all the cookies we use on our website. However, please be aware that doing so may impair our website and its functionality or may even render some or all of it unusable. You should also be aware that clearing all cookies from your browser will also delete any cookies that are storing your preferences, for example, whether you have accepted cookies on a website or any cookies that are blocking other cookies.\",\"section6BrowserLinks\":\"The following links provide more information on cookie settings for commonly used browsers: Cookie settings in Internet Explorer, Cookie settings in Firefox, Cookie settings in Chrome, Cookie settings in Safari web and iOS.\",\"section7Title\":\"Updates on Policy\",\"section7Content\":\"This policy may change from time to time. Your continued use of our platforms after we make changes is deemed to be acceptance of those changes, so please check the policy periodically for updates.\",\"contactTitle\":\"How do you contact us?\",\"contactIntro\":\"In case of any queries related to this policy, you can contact our Data Privacy Office in one of the following ways.\",\"contact1\":\"Send us a communication to the Data Privacy Office, Emaar Hotels \u0026 Resorts (Dubai), P.O. Box 9440, Dubai, United Arab Emirates.\",\"contact2\":\"Call us at 800-EMAAR (36227)\",\"contact2Tel\":\"tel:80036227\",\"contact3\":\"Email us at customer.privacy@emaar.ae\",\"contact3Email\":\"mailto:customer.privacy@emaar.ae\"},\"events\":{\"heroTitle\":\"Meetings \u0026 Events\",\"heroSubtitle\":\"Exceptional venues for unforgettable occasions\",\"venues\":\"Our Venues\",\"capacity\":\"Capacity\",\"guests\":\"guests\",\"wedding\":\"Weddings\",\"weddingDesc\":\"Create your dream wedding in an iconic setting. Our dedicated events team will ensure every detail reflects your vision.\",\"catering\":\"Catering\",\"cateringDesc\":\"Our culinary team creates bespoke menus for every occasion, from intimate gatherings to grand celebrations.\",\"inquiry\":\"Event Inquiry\",\"inquiryDesc\":\"Contact our events team to discuss your requirements and receive a personalised proposal.\",\"findAVenue\":\"Find A Venue\",\"overview\":\"Overview of event capabilities across our hotels\",\"exploreHotels\":\"Explore our hotel event venues\"},\"eventRequest\":{\"title\":\"Event Request Form\",\"intro\":\"Fill out the form below and we will get in touch with you\",\"requiredNote\":\"\\\"*\\\" indicates required fields\",\"venue\":\"Venue\",\"selectVenue\":\"Select venue type\",\"eventType\":\"Event Type\",\"selectEventType\":\"Select type of event\",\"numberOfAttendees\":\"Number of attendees\",\"selectDate\":\"Select your date\",\"firstName\":\"First Name\",\"lastName\":\"Last Name\",\"phoneCode\":\"Code\",\"phone\":\"Mobile Phone\",\"country\":\"Country\",\"city\":\"City\",\"email\":\"Email\",\"enquiry\":\"Tell us about your enquiry (Optional)\",\"marketingConsent\":\"I agree for my data to be processed in line with the Privacy Policy in order for you to send me marketing and promotional content.\",\"thirdPartyConsent\":\"I agree for my data to be processed in line with the Privacy Policy to enable communication to third parties.\",\"submit\":\"Submit Request\",\"submitting\":\"Submitting...\",\"successMessage\":\"Thank you for your event request. We will contact you shortly.\",\"errorGeneric\":\"An error occurred. Please try again.\",\"errorNetwork\":\"Network error. Please check your connection and try again.\",\"contactInfo\":\"Direct Contact\",\"tel\":\"Tel\",\"email2\":\"Email\",\"validation\":{\"firstNameRequired\":\"First name is required\",\"firstNameTooShort\":\"First name must be at least 2 characters\",\"lastNameRequired\":\"Last name is required\",\"lastNameTooShort\":\"Last name must be at least 2 characters\",\"emailRequired\":\"Email address is required\",\"emailInvalid\":\"Please enter a valid email address\",\"phoneRequired\":\"Phone number is required\",\"phoneInvalid\":\"Please enter a valid phone number (digits only)\",\"phoneTooShort\":\"Phone number must be at least 5 digits\",\"phoneTooLong\":\"Phone number must not exceed 15 digits\",\"attendeesRequired\":\"Number of attendees is required\",\"attendeesMin\":\"Number of attendees must be at least 1\",\"attendeesInvalid\":\"Please enter a valid number\",\"dateRequired\":\"Please select a preferred date\",\"datePast\":\"Selected date cannot be in the past\",\"nameInvalid\":\"Only letters, spaces, hyphens and apostrophes are allowed\"}},\"timeout\":{\"heroTitle\":\"Timeout\",\"heroSubtitle\":\"Discover curated experiences at Armani Hotels\",\"subtitle\":\"TIMEOUT\",\"title\":\"Armani/Timeout\",\"description\":\"Explore a world of exclusive experiences, from private art tours and wellness retreats to culinary workshops and rooftop evenings, all crafted with the signature Armani touch.\",\"faqs\":\"FAQs\",\"backToTimeout\":\"Back to Timeout\",\"backToHotel\":\"Back to Hotel\",\"moreToDiscover\":\"More to Discover\"},\"armaniExperience\":{\"heroTitle\":\"THE ARMANI EXPERIENCE\",\"heroSubtitle\":\"A World of Elegance\",\"subtitle\":\"THE ARMANI EXPERIENCE\",\"title\":\"A World of Elegance\",\"description\":\"Discover the refined world of Armani beyond fashion. From exquisite florals to artisanal confectionery, from wellness sanctuaries to art galleries, experience the complete Armani lifestyle at our hotels.\",\"discoverMore\":\"Discover More\",\"home\":\"Home\"},\"glossary\":{\"title\":\"Hotel Glossary\",\"heroTitle\":\"Hotel Glossary: Essential Terms at Armani Hotel Dubai\",\"heroSubtitle\":\"\",\"description\":\"Essential terms at Armani Hotel Dubai and Armani Hotels \u0026 Resorts.\",\"intro\":\"Welcome to the Armani Hotel Dubai Glossary, your guide to understanding the key terms related to our world-class services and amenities. Whether you're planning your stay or enhancing your experience, this glossary will provide clarity on terms that define our luxury hotel.\",\"sectionTitle\":\"Hotel Glossary\",\"sectionSubtitle\":\"Table including all glossary terms arranged by Alphabitical letters like the example below\",\"A\":{\"Accommodation\":\"Refers to the rooms or spaces provided by the hotel for guests to stay in during their visit. It includes all types of rooms, suites, or other types of lodging offered by the hotel, which may vary in size, style, and amenities.\",\"Advance Payment\":\"An advance payment is an upfront payment for future hospitality services, commonly required for group bookings, extended stays, or luxury accommodations.\",\"ALOS\":\"Acronym for average length of stay.\",\"All-inclusive Rate\":\"Rate that includes bed, breakfast, lunch and dinner in selected dining venues available at the hotel.\",\"Amenities\":\"Facilities and services that a hotel offers its guests, such as free Wi-Fi, laundry service, or a swimming pool.\",\"ARR (Average Room Rate)\":\"A measure of the average rate paid by hotel guests per room sold, calculated by dividing Gross Rooms Revenue by the number of rooms paid for by hotel guests over a given period.\",\"Arrival\":\"Arrival refers to the moment a guest reaches the hotel and completes the check-in process. This phase encompasses engagement with staff such as doormen or porters, completion of check-in formalities, allocation of rooms, distribution of keys, and management of luggage.\",\"Attractions\":\"Places that tourists want to visit, like museums, theme parks, or historic sites\"},\"B\":{\"Booking Engine\":\"Technology that allows reservations to be made on a website.\",\"BAR (Best Available Rate)\":\"This is a property's published base rate that doesn't require pre-payment and doesn't impose additional cancellation fees.\",\"B\u0026B\":\"Rates that cover both bed and breakfast.\",\"Banquet\":\"A formal, often celebratory, meal prepared for numerous guests.\",\"Ball Room\":\"A large room in a hotel used for hosting events like weddings, conferences, or parties.\",\"Booking Agent\":\"An individual responsible for managing accommodation reservations for individuals, groups, or travel intermediaries.\",\"Brand Standards\":\"The standards for a particular hotel brand, which determine (among other things) its design, the fit-out and operational requirements for that brand. Brand Standards are set by the brand owner (usually the Operator) and updated from time to time. The Owner will be expected to fund these updates throughout the Operating Plan.\",\"Boutique Hotel\":\"Intimate, upscale hotels that distinguish themselves from larger chains through personalized service and unique offerings.\",\"Butler Service\":\"A hospitality service where servers provide guests with light bites directly from serving trays.\"},\"C\":{\"Chain Hotel\":\"A hotel which is a member of a chain or group of hotels, including a Chain Scale.\",\"Check In\":\"The procedure where a guest officially registers at a hotel and receives their room key or key card.\",\"Check Out\":\"The act of a guest finalizing their hotel bill and returning the room key or key card upon departure.\",\"Concierge\":\"A hotel staff member who assists guests with obtaining services and information about external attractions and amenities.\"},\"D\":{\"Day Guests\":\"Individuals who utilize hotel services during the day and depart the same day.\",\"Direct Booking\":\"Direct bookings are those made on a hotel website, as opposed to reservations made through OTAs, travel agencies and other third-party networks.\",\"Double Room\":\"An accommodation option featuring two beds for duo occupancy.\",\"Duty Manager\":\"The person responsible for the day-to-day operations of a hotel.\"},\"E\":{\"Early Arrival\":\"A pre-arranged understanding permitting guests to check into their hotel accommodations ahead of the conventional check-in schedule.\",\"En-suite\":\"A private bathroom directly accessible from a bedroom.\"},\"F\":{\"F\u0026B\":\"An abbreviation commonly used in the hospitality industry for food and beverage.\",\"Front of House\":\"The reception area, concierge and porter services.\",\"Frequency Programme\":\"A loyalty scheme or frequent traveller programme. Front of House The reception area, concierge and porter services.\"},\"G\":{\"Guest Services\":\"The array of services and conveniences offered by a hotel to ensure a pleasant stay for guests. Examples of guest services might involve complimentary in-room tea and coffee facilities, or the provision of daily newspapers.\"},\"H\":{\"Half-Board\":\"A lodging option that includes accommodation, breakfast, and one main meal, typically either lunch or dinner.\",\"Half-Pension\":\"Similar to half-board, where the package includes accommodation, breakfast, and specifically dinner as the second meal.\",\"High Season\":\"The busiest time of year for hospitality and tourism businesses, when the most people visit and prices are usually higher.\"},\"I\":{\"Incidental Charges\":\"Additional expenses beyond the basic hotel room rate, such as for parking, internet access, and in-room entertainment.\"},\"L\":{\"Late Charge\":\"Expenses incurred during a guest's stay that are billed after their departure, such as for telephone usage or minibar items not accounted for at check-out.\",\"Late Check-Out\":\"An option for guests to vacate their rooms after the customary check-out time.\",\"Late Show\":\"A guest who turns up after the scheduled arrival time stated in their booking.\",\"Loyalty Programme/Scheme\":\"An incentive plan offered by hotels to reward guests for repeated stays by offering points or benefits that can be exchanged for discounts or complimentary services.\",\"Length of Stay\":\"The number of nights that a guest spends in a hotel.\"},\"M\":{\"Mattress Run\":\"A traveler who is staying a number of nights in order to rack up points for their frequent stay program specific to that hotel chain.\"},\"N\":{\"No-Show\":\"A reservation status when the guest fails to arrive and does not provide prior cancellation notice.\",\"Non In-house Guest\":\"A guest who, without reservation, walks into a hotel in search of a room or dining experience.\"},\"O\":{\"Occupancy\":\"The measure of fill by dividing the total number of rooms occupied by the number of rooms available.\",\"Off-peak\":\"The time of year when tourism is at its lowest\",\"Online Check-in\":\"A process where guests have the option to complete their check-in procedures over the internet before their arrival at the hotel, with some systems allowing bypassing the front desk altogether or using an express line to simply collect their room key.\",\"On-site Restaurant\":\"A dining establishment that is situated within the hotel's property.\",\"OOO\":\"Acronym for Out of Order, indicating that a room or service is temporarily unavailable.\"},\"P\":{\"Preferred Rate\":\"A negotiated rate between the hotel and a specific client.\",\"Pre-Payment\":\"A pre-payment is a partial or full payment made before a guest's stay to secure a reservation, often required for non-refundable bookings or special promotions.\",\"Programme\":\"A schedule that gives the details and times for pieces of the event agenda.\"},\"Q\":{\"Quin\":\"Hotel rooms that can accommodate up to five people.\"},\"R\":{\"Rack Rate\":\"The original price of a hotel room before any discounts or promotional rates are applied.\",\"Reception\":\"Refers to the check-in desk of the hotel.\",\"Refreshment Break\":\"Period between sessions of an event that is accompanied by snacks and beverages.\",\"Room Category\":\"Type of rooms based on room size, amenities included and room spec ex. With balcony or fountain view\",\"Room Class\":\"A grouping of rooms based on similar value characteristics.\",\"Room Night\":\"A room being occupied by one or more guests for one night.\"},\"S\":{\"Site Inspection\":\"A tour of a location by an event planner to see if it meets their needs for an event.\"},\"V\":{\"Very Important Person (VIP)\":\"Individual who should receive special or elevated treatment based on their role or relationship to an event.\",\"Vacancy\":\"A room that is available to be booked.\",\"Valet Parking\":\"A service where an employee parks and retrieves guests' vehicles.\"},\"W\":{\"Walk-in\":\"A guest who, without a reservation, walks into a hotel in search of a room.\"}},\"about\":{\"title\":\"About Us\",\"description\":\"Discover the story and philosophy behind Armani Hotels \u0026 Resorts.\",\"heading\":\"Stay with Armani\",\"paragraph1\":\"The collection of Armani Hotels \u0026 Resorts reflects the pure elegance, simplicity and sophisticated comfort that embody the designer's signature style and aesthetic, bringing to life the 'Stay with Armani' philosophy characterised by excellence in service.\",\"paragraph2\":\"Understated elegance, uncompromising attention to detail and stunning views meet world-class services and unmatched culinary offerings, ensuring an unforgettable experience for guests staying at our urban retreats.\",\"paragraph3\":\"From Armani Hotel Dubai in the iconic Burj Khalifa to Armani Hotel Milano in the heart of the fashion district, each property has been carefully curated by Giorgio Armani to offer a harmonious blend of design, comfort and exceptional service.\"},\"legalDisclaimer\":{\"title\":\"Legal Disclaimer\",\"description\":\"Legal disclaimer and terms for Armani Hotels \u0026 Resorts.\",\"section1Title\":\"COMMON DECLAIMER\",\"section1Content\":\"$2b\",\"section2Title\":\"EMAAR PRIVACY POLICY\",\"section2Content\":\"Emaar Hotels \u0026 Resorts LLC and its subsidiaries and affiliated companies (hereinafter referred to as 'Emaar Hotels \u0026 Resorts LLC' 'us' 'we' or 'our') is committed to respecting your privacy and to complying with applicable data protection and privacy laws. You can visit www.armanihoteldubai.com without disclosing any personally identifiable information about yourself. We have provided this Privacy Policy Statement to help you understand how we collect, use and protect your information when you visit the Site. We wish to help you make informed decisions, so please take a few moments to read the sections below and learn how we may use your personal information. You should read this notice in conjunction with the Terms and Conditions of use for the Site.\",\"section3Title\":\"ACCEPTANCE\",\"section3Content\":\"By using this site, you signify your agreement to the Emaar Hotels \u0026 Resorts LLC Privacy Policy. If you do not agree with this policy, please do not use this site. Your continued use of Emaar Hotels \u0026 Resorts LLC and/or its affiliates' sites following the posting of changes to these terms will mean you accept those changes.\",\"section4Title\":\"1. What kind of information is collected?\",\"section4Content\":\"Anonymous Information – Anonymous information cannot be tied directly to personally identifiable information. We use this information to improve our site. This information helps us focus our resources on the features that are most popular with our customers. We may collect information regarding your IP address, browser type, domain name and access time. This information is used for our own research purposes and is separate from any personally identifiable information that you may submit via this site. We do not link IP addresses to any personal information. In rare instances, IP addresses may be used to assist in deterring and/or preventing abusive or criminal activity on the website.\",\"section5Title\":\"2. Personally Identifiable Information\",\"section5Content\":\"The following forms on www.armanihoteldubai.com collect Personally Identifiable Information: Events Request Form – Information provided through this form will not be stored by www.armanihoteldubai.com and will be used solely to respond to customer enquiries and/or service requests. Contact Us Form – Information provided through this form will not be stored by www.armanihoteldubai.com and will be used solely to respond to customer enquiries and/or service requests. Register for Newsletter – Information in this form will be used to send www.armanihoteldubai.com's periodic Newsletter updating customers.\",\"section6Title\":\"3. How safe will my information be?\",\"section6Content\":\"The security of all information associated with our Customers is an important concern to us. We, at www.armanihoteldubai.com therefore exercise the utmost care in providing secure transmission of your information from your computer to our servers. Unfortunately, no data transmission over the Internet can be guaranteed to be 100% secure. As a result, while we strive to protect your information, Emaar Hotels \u0026 Resorts LLC and its affiliates can't ensure or warrant the security of any information you transmit to us or from our online products or services, and you do so at your own risk. Once we receive your transmission, Emaar Hotels \u0026 Resorts LLC uses industry standard efforts to safeguard the confidentiality of your information, such as firewalls and Secure Socket Layers. However, 'perfect security' does not exist on the Internet.\",\"section7Title\":\"4. Who will use this information?\",\"section7Content\":\"As a general rule, Emaar Hotels \u0026 Resorts LLC will not disclose any specific personal information that you submit to us about you ('Personal Information') in a manner that connects you with the Personal Information, except when we have your explicit permission or under special circumstances, such as when we believe in good faith that the law requires it or under the circumstances described below.\",\"section8Title\":\"5. How can I control my information?\",\"section8Content\":\"In case you change your mind or some Personal Information changes (such as your mailing address or e-mail address), we will try to provide a way to correct, update or remove the Personal Information that you have provided us. We offer Customers the opportunity to 'opt out' of having Personal Information shared with Emaar Hotels \u0026 Resorts LLC and/or its affiliated companies such as un-registering from the www.armanihoteldubai.com Newsletter. The website uses Tracking Technologies and Advertising, you can set your browser to refuse all or some browser cookies, or to alert you when cookies are being sent. If you disable or refuse cookies, please note that some parts of this site may then be inaccessible or not function properly. Additionally, If a Customer wishes to update Personal Information or objects to any usage provided herein for any reason, he/she may e-mail the requested change to: \",\"section8Email\":\"mailto:media@armanihotels.com\",\"section8EmailLabel\":\"media@armanihotels.com\",\"section9Title\":\"COOKIES AND OTHER TECHNOLOGIES\",\"section9Content\":\"$2c\",\"section10Title\":\"TERMS \u0026 CONDITIONS\",\"section10Content\":\"Please read these Terms and Conditions carefully. These are the general Terms and Conditions governing your access and use of this website ('Site'). IF YOU DO NOT AGREE WITH THESE TERMS AND CONDITIONS, PLEASE DO NOT USE THIS SITE. By continuing to use the Site and/or any of the services shown on the Site, you agree to be bound by these Terms and Conditions.\",\"section11Title\":\"ACCEPTANCE\",\"section11Content\":\"By using this site, you signify your agreement to Emaar Hotels \u0026 Resorts LLC's Terms and Conditions. IF YOU DO NOT AGREE WITH THIS POLICY, PLEASE DO NOT USE THIS SITE. Your continued use of Emaar Hotels \u0026 Resorts LLC and/or its affiliates' sites following the posting of changes to these terms will mean you accept those changes.\",\"section12Title\":\"COPYRIGHT © Emaar Hotels \u0026 Resorts LLC 2005, ALL RIGHTS RESERVED.\",\"section12Content\":\"Copyright in the pages and in the screens displaying the pages, and in the information and material therein and in their arrangement, is owned by Emaar Hotels \u0026 Resorts LLC unless otherwise indicated.\",\"section13Title\":\"TRADEMARKS\",\"section13Content\":\"Emaar Hotels \u0026 Resorts LLC, its subsidiaries, affiliates, contractors and/or participating corporations are the owners of the trade and service marks appearing on this website and all rights are reserved in respect of such trade and service marks.\",\"section14Title\":\"USE OF INFORMATION AND MATERIALS\",\"section14Content\":\"The information and materials contained in these pages – and the terms, conditions, and descriptions that appear – are subject to change. Not all products and services are available in all geographic areas. Your eligibility for particular products and services is subject to Emaar Hotels \u0026 Resorts LLC's final determination and acceptance.\",\"section15Title\":\"NO WARRANTY\",\"section15Content\":\"The information and materials contained in this site, including text, graphics, links or other items – are provided 'as is,' 'as available'. Emaar Hotels \u0026 Resorts LLC does not warrant the accuracy, adequacy or completeness of the information and materials and expressly disclaims liability for errors or omissions therein. No warranties of any kind, implied, express or statutory, including but not limited to the warranties of non-infringement of third party rights, title, merchantability, fitness for a particular purpose and freedom from computer virus, are given in conjunction with the information and materials.\",\"section16Title\":\"EXCLUSION OF LIABILITY\",\"section16Content\":\"In no event will Emaar Hotels \u0026 Resorts LLC be liable for any damages, including without limitation direct or indirect, special, incidental, or consequential damages, losses or expenses arising in connection with this site or use thereof or inability to use by any party, or reliance on the contents of this site, or in connection with any failure of performance, error, omission, interruption, defect, delay or failure in operation or transmission, computer virus or line or system failure, even if Emaar Hotels \u0026 Resorts LLC, its representatives, are advised of the possibility of such damages, losses or expense, hyperlinks to other internet resources are at your own risk; the content, accuracy, opinions expressed, and other links provided by these resources are not investigated, verified, monitored, or endorsed by Emaar Hotels \u0026 Resorts LLC. This Exclusion clause shall take effect to the fullest extent permitted by law.\",\"section17Title\":\"SUBMISSION\",\"section17Content\":\"All information submitted to Emaar Hotels \u0026 Resorts LLC via this site shall be deemed and remain the property of Emaar Hotels \u0026 Resorts LLC who shall be free to use, for any purpose, any ideas, concepts, know-how or techniques contained in information a visitor to this site provides Emaar Hotels \u0026 Resorts LLC through this site. Emaar Hotels \u0026 Resorts LLC shall not be subject to any obligations of confidentiality or privacy regarding submitted information except as agreed by the Emaar Hotels \u0026 Resorts LLC or as otherwise specifically agreed or required by law.\",\"section18Title\":\"VARIATION\",\"section18Content\":\"These terms and conditions are subject to change and can be modified at any time without notice.\",\"section19Title\":\"GOVERNING LAW \u0026 JURISDICTION\",\"section19Content\":\"By accessing this website and obtaining the facilities, products or services offered through this website, you agree that the law of the United Arab Emirates (UAE) shall govern such access and the provision of such facilities, products and services and you agree to submit to the exclusive jurisdiction of the UAE courts.\",\"contactTitle\":\"Contact\",\"contactText\":\"For questions regarding this disclaimer, please contact us at\"},\"careers\":{\"title\":\"Careers\",\"description\":\"Join the team at Armani Hotels \u0026 Resorts.\",\"heading\":\"Grow with us\",\"paragraph1\":\"At Armani Hotels \u0026 Resorts we are committed to excellence in hospitality. We look for passionate individuals who share our dedication to service, design and the Armani philosophy.\",\"paragraph2\":\"If you are interested in joining our team, we invite you to get in touch with us.\",\"cta\":\"Contact us\"},\"whistleblowing\":{\"title\":\"Whistleblowing\",\"description\":\"Information on how to report concerns at Armani Hotels \u0026 Resorts.\",\"content\":\"Armani Hotels \u0026 Resorts is committed to the highest standards of conduct and transparency. We provide a channel for reporting concerns regarding possible wrongdoing, including fraud, corruption or other serious breaches of law or policy. Reports can be made in confidence and will be handled in accordance with applicable procedures.\",\"contactTitle\":\"Contact\",\"contactText\":\"For whistleblowing reports or questions, please contact\"},\"find\":{\"title\":\"Find Rooms\",\"description\":\"Search for availability and book your stay at Armani Hotels \u0026 Resorts.\",\"heading\":\"Find your stay\",\"intro\":\"Discover availability at Armani Hotel Dubai and Armani Hotel Milano. Choose your dates and preferences to view room options and special offers.\",\"ctaBook\":\"Book Now\",\"ctaFindRooms\":\"Find Rooms\"},\"roomsUnavailable\":{\"title\":\"Rooms Unavailable\",\"description\":\"No rooms available for your selected dates.\",\"message\":\"We're sorry, but there are no rooms available for your selected dates. Please try different dates or contact us for assistance.\",\"cta\":\"Back to Home\"},\"aboutMilano\":{\"metaTitle\":\"Luxury Hotel Milano, philosophy of Giorgio Armani | Armani Hotel Milano\",\"metaDescription\":\"Armani Hotel Milano embodies Giorgio Armani's design and lifestyle philosophy, promising a home-away-from-home experience in Milan's fashion district.\",\"heroEyebrow\":\"MILAN\",\"heroTitle\":\"Home Away From Home\",\"heroBody\":\"Armani Hotel Milano is a place that embodies Giorgio Armani's design and lifestyle philosophy, and promises a \\\"home-away-from-home\\\" experience, delivering luxurious comfort and a unique experience. While Armani Hotel Milano means many things to many people, gorgeous getaway, gourmet heaven or health and wellness oasis, the only constant is our hospitality whose every facet is designed around you – our guest – to ensure you get the most out of your stay and your visit to Milan.\",\"section2Eyebrow\":\"ARMANI HOTEL MILANO\",\"section2Title\":\"Quadrilatero della Moda\",\"section2Body\":\"Armani Hotel Milano is situated in the prestigious Manzoni 31 building in Milan, Italy, anchoring the world-famous fashion district known as the Quadrilatero della Moda. It is only a few minutes away from the luxury shopping streets of Via Montenapoleone and Via della Spiga, the famous Teatro alla Scala, the spectacular Piazza del Duomo, the most important museums and the nightlife district.\",\"virtualTourHeading\":\"Virtual Tour\",\"virtualTourLink\":\"Emotions at 360°\",\"newsletterText\":\"Sign up to receive exclusive offers and news from Armani Hotels \u0026 Resorts\",\"discoverMore\":\"DISCOVER MORE\"},\"aboutDubai\":{\"metaTitle\":\"About Us – Armani Hotel Dubai\",\"metaDescription\":\"Armani Hotels \u0026 Resorts brings together the impeccable taste of Giorgio Armani and the developmental expertise of Emaar Hotels \u0026 Resorts.\",\"heroEyebrow\":\"OUR STORY\",\"heroTitle\":\"Luxury Hotels\",\"heroBody\":\"Armani Hotels \u0026 Resorts brings together the impeccable taste of Giorgio Armani and the developmental expertise of Emaar Hotels \u0026 Resorts. The Emaar – Giorgio Armani partnership is truly global in nature. Emaar, one of the world's leading integrated lifestyle developers, and Giorgio Armani, one of the world's leading fashion icons, together create a brand and a product that is unsurpassed in innovative design, style, form, and function.\",\"section2Title\":\"ARMANI HOTEL DUBAI\",\"section2Body\":\"Nestled in the world's tallest tower, occupying concourse level through to level 8 and levels 38 and 39, Armani Hotel Dubai offers sweeping views across the city and Arabian Gulf. With its own dedicated entrance, it is situated within walking distance of The Dubai Mall, the world's largest retail destination, set within the vibrant Downtown Dubai business and leisure district.\",\"sustainabilityTitle\":\"OUR SUSTAINABILITY COMMITMENT\",\"sustainabilityBody\":\"Armani Hotel Dubai is committed to preserving precious resources and creating a sustainable operation that benefits our guests, colleagues, the local community and ultimately, the planet. Our environmental policy follows Emaar Hospitality and Dubai Government exacting codes of practice. The hotel is Green Globe certified and is committed towards addressing energy consumption, air quality, and waste management and explore biodiversity initiatives, green procurement solutions and social sustainability opportunities.\",\"verifiedTitle\":\"GLOBALLY VERIFIED™, PROUDLY RESPONSIBLE\",\"verifiedBody\":\"Armani Hotel Dubai has earned the 2025 Responsible Hospitality VERIFIED™, an industry-leading designation for hotels that follow best practices to protect the environment and support the well-being of employees, guests and the community. Responsible Hospitality is recognized by Forbes Travel Guide, the global authority on hospitality excellence, as the official sustainability verification for its community of Star-Rated hotels in more than 80 countries.\",\"newsletterText\":\"Sign up to receive exclusive offers and news from Armani Hotels \u0026 Resorts\",\"discoverMore\":\"DISCOVER MORE\"},\"winterPassion\":{\"title\":\"Winter Passion\",\"description\":\"Winter Passion at Armani Hotel Milano – sport, dining and EA7.\",\"heading\":\"Winter Passion\",\"intro\":\"Explore the special program created to celebrate the passion for sport and immerse yourself in the energy of this moment and let yourself be carried away by the vibrant atmosphere that will enliven the city. Discover our initiatives and our gourmet offerings.\",\"block1Eyebrow\":\"ARMANI/BAMBOO BAR\",\"block1Title\":\"Enjoy the winter passion in an exclusive setting\",\"block1Body\":\"From February 6 to 22, the Armani/Bamboo Bar celebrates the dynamism and beauty of athletic movement. Through a scenic LED wall, images of the competitions will flow like a sophisticated visual backdrop. A silent tribute to sport, offering a refined and sensory experience.\",\"block1ViewMenu\":\"View Menu\",\"block1Reserve\":\"Reserve a Table\",\"block2Eyebrow\":\"ARMANI/BAMBOO BAR\",\"block2Title\":\"Beyond the snow Flavour takes shape\",\"block2Body\":\"Discover our mixology creations inspired by ice and snow, available at the Armani/Bamboo Bar from February 6 to 28. Let yourself be captivated by the three‑dimensional tiramisù, Snow Peak, a unique creation that elevates the experience with a touch of haute pâtisserie.\",\"block2ViewMenu\":\"View Menu\",\"block2Reserve\":\"Reserve a Table\",\"block3Eyebrow\":\"ARMANI HOTEL MILANO\",\"block3Title\":\"EA7 Slalom Pass\",\"block3Body\":\"Follow the rhythm of the city. Experience the city's energy through a route inspired by the great winter challenges. With the exclusive EA7 Slalom Pass, you become the protagonist of an urban itinerary that touches the \\\"4 gates\\\" of the EA7 universe, including the Armani Hotel Milano. Validate each stage of your journey and, at the finish line, celebrate your passion for sport by collecting the iconic EA7 pin for the Italia Team at the EA7 Boutique in Via Manzoni 37. The elegance of movement awaits you.\",\"cta\":\"Back to Hotel\",\"block1MenuUrl\":\"https://www-armanihotels-com.azureedge.net/wp-content/uploads/2026/01/Winter-Olympic-Games-Menu-v-3.png\",\"block1ReserveUrl\":\"https://www.armanihotels.com/en/restaurant/armani-bamboo-bar/?hotel=armani-hotel-milano\",\"block2MenuUrl\":\"https://www-armanihotels-com.azureedge.net/wp-content/uploads/2026/01/Winter-Olympic-Games-Menu-v-3.png\",\"block2ReserveUrl\":\"https://www.opentable.it/r/armani-bamboo-bar-armani-hotel-milano?lang=en-gb\"},\"ramadan\":{\"title\":\"Ramadan Nights by Armani\",\"description\":\"Iftar and Suhoor at Armani Hotel Dubai in Burj Khalifa.\",\"heading\":\"Ramadan Nights by Armani\",\"intro\":\"A month rich in meaning. Moments made for gathering. This Ramadan, we welcome you home to where the season's spirit meets unmistakable Armani style. Under the quiet glow of February's starlit skies, Armani/Pavilion once again transforms into the city's most atmospheric setting for open-air iftar and sohour. Guided by the calm presence of the crescent moon, break your fast or meet before dawn in a space designed for reflection and connection, framed by soulful oud performances and the iconic rhythm of the Dubai Fountain. For inquiries, please call +971 4 888 3666 or email restaurant.reservations@armanihotels.com\",\"introEmail\":\"mailto:restaurant.reservations@armanihotels.com\",\"introEmailLabel\":\"restaurant.reservations@armanihotels.com\",\"block1Eyebrow\":\"ARMANI/PAVILION\",\"block1Title\":\"A WORLD OF IFTAR FLAVOURS\",\"block1Body\":\"Evenings at Armani/Pavilion are framed by the stillness of the season and the cool winter air, an al fresco Iftar and Sohour in the heart of Downtown Dubai. Beneath the crescent moon, a composed ambience unfolds: the soft cadence of oud, the shimmer of the Dubai Fountain, and the understated elegance of Armani. A curated composition of global flavours. Timeless Middle Eastern classics alongside signature creations from Armani/Ristorante, Armani/Amal, Armani/Hashi, Armani/Mediterraneo and Armani/Deli.\",\"block1Price\":\"AED 410 per person\",\"block1Timing\":\"Available from sunset until 9pm\",\"block1ViewMenu\":\"View Menu\",\"block1Reserve\":\"Reserve a Table\",\"block2Eyebrow\":\"ARMANI/PAVILION\",\"block2Title\":\"A SOCIAL SOHOUR TO SAVOUR\",\"block2Body\":\"Ramadan invites us to slow down, reconnect and enjoy meaningful social interaction with family, friends, and the community. Armani/Pavilion remains the city's go-to sohour address, offering an atmosphere and culinary buffet that capture the heart of the season. Savour regional favourites and global influences. Share stories, unwind, and take in the moment as traditional melodies and the Dubai Fountain show come together to feed the soul.\",\"block2Price\":\"AED 295 per person\",\"block2Timing\":\"Available from 10pm to 2am\",\"block2ViewMenu\":\"View Menu\",\"block2Reserve\":\"Reserve a Table\",\"block3Eyebrow\":\"ARMANI/AMAL\",\"block3Title\":\"IFTAR WITH INDIAN FLAVOURS\",\"block3Body\":\"This Ramadan, experience Iftar at Armani/Amal, where authentic Indian flavours are presented with contemporary elegance. Set within Burj Khalifa, the restaurant offers panoramic views of Downtown Dubai and the Dubai Fountain, creating a refined setting for moments of togetherness. A four-course Iftar menu for AED 375 per person, is served from sunset, bringing family and friends together over a thoughtfully crafted Ramadan dining experience.\",\"block3ViewMenu\":\"View Menu\",\"block3Reserve\":\"Reserve a Table\",\"block4Eyebrow\":\"ARMANI HOTEL DUBAI\",\"block4Title\":\"A REFINED RAMADAN RETREAT\",\"block4Body\":\"Celebrate Ramadan with an exclusive stay at Armani Hotel Dubai. Enjoy 25% off the Best Available Rate and immerse yourself in a refined retreat designed for comfort, calm, and elegance.\",\"block4Cta\":\"Book Now\",\"block5Eyebrow\":\"ARMANI/SPA\",\"block5Title\":\"RITUALS OF RELAXATION\",\"block5Body\":\"Armani/Spa invites you to restore balance this Ramadan with our signature treatments, crafted to calm the mind and rejuvenate the body. Experience tailored rituals inspired by holistic wellness, delivered in a serene setting overlooking the heart of Downtown Dubai for an elevated sanctuary of meaningful self-care this season.\",\"block5ViewMenu\":\"View Menu\",\"block5BookTreatment\":\"Book A Treatment\",\"block1MenuUrl\":\"/pdfs/Ramadan-Iftar-Menu-2026feb_updated.pdf\",\"block1ReserveUrl\":\"https://www.sevenrooms.com/explore/armanipavilion/reservations/create/search\",\"block2MenuUrl\":\"/pdfs/Ramadan-Sohour-Menu-2026feb_updated-1.pdf\",\"block2ReserveUrl\":\"https://www.sevenrooms.com/explore/armanipavilion/reservations/create/search\",\"block3MenuUrl\":\"/pdfs/AMAL-Ramadan-Iftar-Menu-2026.pdf\",\"block3ReserveUrl\":\"https://www.sevenrooms.com/explore/amal/reservations/create/search?tracking=armani-amal\",\"block4CtaUrl\":\"https://www.armanihotels.com/en/offers/ramadan-exclusive-stay-and-save/?hotel=armani-hotel-dubai\",\"block5MenuUrl\":\"https://emea.spatime.com/ahd9440\",\"block5BookUrl\":\"https://www.armanihotels.com/en/hotels/armani-hotel-dubai/wellness/wellness-treat/spa-request-dubai/\",\"faqTitle\":\"FAQs\",\"faq1Q\":\"What is Ramadan Nights by Armani Hotel?\",\"faq1A\":\"Ramadan Nights by Armani is a serene and elegant seasonal dining experience at Armani/Pavilion, offering exclusive al fresco iftar and suhoor gatherings throughout the holy month of Ramadan. Set in the iconic Burj Khalifa, Armani/Pavilion is one of the most exquisite destinations for this special occasion. Guests can enjoy a tranquil and refined atmosphere, paired with exceptional culinary offerings, all while taking in the breathtaking views of Dubai Fountain.\",\"faq2Q\":\"How to celebrate Ramadan in Dubai?\",\"faq2A\":\"Celebrate Ramadan in Dubai by immersing yourself in the city's unique blend of tradition and luxury. You can break your fast with a delicious iftar at one of the city's world-class restaurants, such as Armani/Pavilion at Armani Hotel Dubai in the iconic Burj Khalifa. Experience the serene atmosphere, enjoy a variety of global flavours, and take in the mesmerising views of Dubai Fountain. Gather with friends and family for a relaxed suhoor or participate in special Ramadan events, all while enjoying the gentle oud melodies that enhance the holy month's reflective spirit.\",\"faq3Q\":\"Is Dubai a good place to visit during Ramadan?\",\"faq3A\":\"Yes, Dubai is an exceptional destination during Ramadan. The city combines rich cultural traditions with luxurious settings, offering exclusive iftar and suhoor experiences at iconic venues like the Armani/Pavilion in Burj Khalifa. Whether you're seeking a peaceful, reflective atmosphere or a social gathering with loved ones, Dubai offers a variety of unique dining experiences paired with stunning views, including Dubai Fountain. The city's festive ambience, along with its world-class hospitality, makes it an unforgettable place to celebrate the holy month of Ramadan.\",\"faq4Q\":\"Can guests enjoy views of Dubai Fountain during Iftar and Suhoor at Armani/Pavilion?\",\"faq4A\":\"Yes, guests dining at Armani/Pavilion during iftar and suhoor are treated to stunning views of the iconic Dubai Fountain. The mesmerising water displays provide a captivating backdrop, enhancing the serene and elegant Ramadan ambience.\",\"faq5Q\":\"Are reservations required for Iftar and Suhoor at Armani Hotel Dubai?\",\"faq5A\":\"Reservations are highly recommended for iftar and suhoor to ensure a seamless dining experience.\",\"faq6Q\":\"What is included in the Iftar and Suhoor experiences at Armani Hotel Dubai?\",\"faq6A\":\"The Iftar experience features a curated selection of traditional dishes, such as ouzi and shawarma, alongside globally inspired flavours, including signature creations from the Michelin-starred Armani/Ristorante. Suhoor offers an elegant buffet of regional and international favourites, perfect for late-night gatherings. Both dining experiences are complemented by breathtaking views of Dubai Fountain, with Burj Khalifa towering above, while the soothing melodies of oud, creating an unforgettable Ramadan ambience.\",\"faq7Q\":\"Can families and children enjoy Iftar and Suhoor at Armani/Pavilion?\",\"faq7A\":\"Absolutely! Armani/Pavilion offers a family-friendly setting, including a dedicated kids' corner. Families can enjoy a relaxed evening while their little ones are thoughtfully catered to in a welcoming atmosphere.\",\"cta\":\"Back to Hotel\"}},\"now\":\"$undefined\",\"timeZone\":\"UTC\",\"children\":\"$L2d\"}]\n"])</script><script>self.__next_f.push([1,"c:[[\"$\",\"section\",null,{\"className\":\"relative min-h-screen overflow-hidden bg-[#1a1a1a]\",\"children\":[[\"$\",\"$L2e\",null,{\"src\":\"https://cms.armanihotels.com/uploads/frame_01_d92701085f.jpg\",\"alt\":\"Armani Hotels \u0026 Resorts\",\"fill\":true,\"priority\":true,\"fetchPriority\":\"high\",\"qu