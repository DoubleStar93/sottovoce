script>self.__next_f.push([1,"As you navigate through and interact with our Website, we may automatically collect certain information about your equipment, browsing actions and patterns. The technologies we use for this automatic data collection may include: Web Beacons. Pages of our the Website and our e-mails may contain small electronic files known as web beacons (also referred to as clear gifs, pixel tags and single-pixel gifs) that permit the Company, for example, to count users who have visited those pages or opened an e-mail and for other related website statistics. Flash Cookies. Certain features of our Website may use local stored objects (or Flash cookies) to collect and store information about your preferences and navigation to, from and on our Website. Flash cookies are not managed by the same browser settings as are used for browser cookies. Cookies (or browser cookies). A cookie is a small file placed on the hard drive of your computer. You may refuse to accept browser cookies by activating the appropriate setting on your browser. However, if you select this setting you may be unable to access certain parts of our Website. Unless you have adjusted your browser setting so that it will refuse cookies, our system will issue cookies when you direct your browser to our Website."])</script><script>self.__next_f.push([1,"29:[\"$\",\"$L2a\",null,{\"formats\":\"$undefined\",\"locale\":\"en\",\"messages\":{\"common\":{\"bookNow\":\"Book Now\",\"learnMore\":\"Learn More\",\"viewAll\":\"View All\",\"viewMore\":\"View More\",\"viewDetails\":\"View Details\",\"readMore\":\"Read More\",\"seeMore\":\"See More\",\"seeLess\":\"See Less\",\"close\":\"Close\",\"back\":\"Back\",\"next\":\"Next\",\"submit\":\"Submit\",\"cancel\":\"Cancel\",\"save\":\"Save\",\"loading\":\"Loading...\",\"accept\":\"Accept\",\"decline\":\"Decline\",\"cookieMessage\":\"We use cookies to enhance your experience. By continuing to visit this site, you agree to our use of cookies.\",\"search\":\"Search\",\"filter\":\"Filter\",\"sortBy\":\"Sort By\",\"share\":\"Share\",\"print\":\"Print\",\"download\":\"Download\",\"from\":\"From\",\"perNight\":\"per night\",\"night\":\"Night\",\"nights\":\"Nights\",\"guest\":\"Guest\",\"guests\":\"Guests\",\"adult\":\"Adult\",\"adults\":\"Adults\",\"child\":\"Child\",\"children\":\"Children\",\"room\":\"Room\",\"rooms\":\"Rooms\",\"checkIn\":\"Check In\",\"checkOut\":\"Check Out\",\"date\":\"Date\",\"time\":\"Time\",\"all\":\"All\",\"yes\":\"Yes\",\"no\":\"No\",\"or\":\"Or\",\"and\":\"And\",\"discoverMore\":\"Discover More\",\"add\":\"Add\",\"remove\":\"Remove\",\"tour360\":\"360° Tour\",\"goBack\":\"Go Back\",\"contentComingSoon\":\"Content coming soon.\",\"of\":\"of\",\"explore\":\"Explore\"},\"nav\":{\"home\":\"Home\",\"hotelsAndResorts\":\"Hotels \u0026 Resorts\",\"restaurants\":\"Restaurants\",\"offers\":\"Offers\",\"blog\":\"Blog\",\"mediaCenter\":\"Media Center\",\"contact\":\"Contact\",\"manageBooking\":\"Manage Booking\",\"signIn\":\"Sign In\",\"signOut\":\"Sign Out\",\"myAccount\":\"My Account\",\"language\":\"Language\",\"stay\":\"Stay\",\"dine\":\"Dine\",\"wellness\":\"Wellness\",\"events\":\"Events\",\"ramadan\":\"Ramadan\",\"armaniExperience\":\"Armani Experience\",\"timeOut\":\"Time Out\",\"giftVoucher\":\"Gift Voucher\",\"tour360\":\"360 Tour\",\"armaniHotelsAndResorts\":\"Armani Hotels \u0026 Resorts\",\"myDashboard\":\"My Dashboard\",\"armaniHotelDubai\":\"Armani Hotel Dubai\",\"armaniHotelMilano\":\"Armani Hotel Milano\",\"unitedArabEmirates\":\"United Arab Emirates\",\"dubai\":\"Dubai\",\"italy\":\"Italy\",\"milan\":\"Milan\"},\"home\":{\"heroTitle\":\"Armani Hotels \u0026 Resorts\",\"heroSubtitle\":\"Where Style Meets Luxury\",\"featuredHotels\":\"Our Hotels\",\"featuredOffers\":\"Featured Offers\",\"latestNews\":\"Latest News\",\"discoverMore\":\"Discover More\",\"stayWithArmani\":\"Stay With Armani\",\"stayWithArmaniDesc\":\"Discover a world of unparalleled luxury where Giorgio Armani's vision of sophisticated elegance comes to life. Every detail, from custom furnishings to personalised service, reflects the Armani philosophy of understated beauty and impeccable style.\",\"milanoTitle\":\"Armani Hotel Milano\",\"milanoDesc\":\"Located in the heart of Milan's fashion district, Armani Hotel Milano offers an intimate luxury experience within the iconic building designed by Enrico A. Griffini.\",\"dubaiTitle\":\"Armani Hotel Dubai\",\"dubaiDesc\":\"Occupying levels from the concourse to the 39th floor of the Burj Khalifa, the world's tallest building, Armani Hotel Dubai is the definitive expression of style and luxury.\",\"exceptionalTitle\":\"An Exceptional World of Luxury\",\"exceptionalDesc\":\"From refined dining to transformative wellness experiences, Armani Hotels \u0026 Resorts invites you to explore a world where every moment is curated with the same meticulous attention that defines the Armani brand.\",\"stayEyebrow\":\"STAY\",\"stayTitle\":\"Rooms \u0026 Suites\",\"stayDesc\":\"Every room and suite is an Armani design masterpiece — serene, luxurious and conceived with every comfort in mind.\",\"armaniHotelDubai\":\"Armani Hotel Dubai\",\"armaniHotelMilano\":\"Armani Hotel Milano\",\"dineEyebrow\":\"DINE\",\"dineTitle\":\"Restaurants \u0026 Lounges\",\"dineDesc\":\"Savour world-class cuisine in settings that embody Giorgio Armani's refined aesthetic.\",\"relaxEyebrow\":\"RELAX\",\"relaxTitle\":\"Wellness \u0026 Spa\",\"relaxDesc\":\"Rejuvenate body and mind in our sanctuaries of calm. Armani/SPA offers bespoke treatments to nourish and revitalise.\",\"sustainabilityEyebrow\":\"SUSTAINABILITY\",\"sustainabilityTitle\":\"Our Commitment to the Future\",\"sustainabilityDesc\":\"Guided by Giorgio Armani's values, we are committed to responsible practices that protect the planet.\",\"futureEyebrow\":\"COMING SOON\",\"futureTitle\":\"Future Destinations\",\"futureDesc\":\"The Armani Hotels \u0026 Resorts family is growing. Discover the new destinations that will continue to redefine luxury hospitality.\",\"futureExplore\":\"Explore Our Story\",\"growEyebrow\":\"PARTNERSHIP\",\"growTitle\":\"Grow With Us\",\"growDesc\":\"Join the Armani Hotels \u0026 Resorts family. We are always seeking partners who share our commitment to excellence.\",\"growConnect\":\"Contact Us\",\"newsletterText\":\"Subscribe to our newsletter for exclusive offers and news from the world of Armani Hotels \u0026 Resorts.\",\"emailPlaceholder\":\"Enter your email\",\"subscribe\":\"Subscribe\"},\"hotel\":{\"overview\":\"Overview\",\"roomsAndSuites\":\"Rooms \u0026 Suites\",\"backToRoomsAndSuites\":\"Back to Rooms \u0026 Suites\",\"dining\":\"Dining\",\"offers\":\"Offers\",\"experiences\":\"Experiences\",\"wellness\":\"Wellness \u0026 Spa\",\"meetings\":\"Meetings \u0026 Events\",\"gallery\":\"Gallery\",\"contact\":\"Contact\",\"location\":\"Location\",\"amenities\":\"Room Amenities\",\"floorPlan\":\"Floor Plan\",\"viewRoom\":\"View Room\",\"termsAndConditions\":\"Terms \u0026 conditions for this room\",\"otherRooms\":\"Other Rooms You May Like\",\"selectRoom\":\"Select Room\",\"roomDetails\":\"Room Details\",\"roomFeatures\":\"Features\",\"startingFrom\":\"Starting From\",\"whatsapp\":\"WhatsApp\",\"hotelNotFound\":\"Hotel Not Found\",\"explore\":\"Explore\",\"fitnessCenter\":\"Fitness Center\",\"bedType\":\"Bed Type\",\"roomType\":\"Room Type\",\"view\":\"View\",\"stayEyebrow\":\"STAY\",\"luxuryHospitalityAt\":\"Luxury Hospitality at {hotelName}\",\"wellnessEyebrow\":\"WELLNESS\",\"unwindWith\":\"Unwind With {hotelName}\",\"faqsTitle\":\"FAQs\",\"contactUsTitle\":\"Contact Us\",\"discoverRoomsBelow\":\"Discover more of our rooms and suites below.\",\"showFilters\":\"Show Filters\",\"hideFilters\":\"Hide Filters\",\"noRoomsFound\":\"No Rooms Found\",\"noRoomsFilterMessage\":\"Unfortunately, no rooms with the selected filters are available. To view available rooms, clear one or more filters.\",\"clearFilters\":\"Clear Filters\"},\"booking\":{\"title\":\"Book 