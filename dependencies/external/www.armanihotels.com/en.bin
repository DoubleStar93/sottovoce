ortant;flex:1!important;text-align:center!important}' +\n  '}';\n\nfunction injectStyles() {\n  if (!document.getElementById('iubenda-armani-overrides')) {\n    var s = document.createElement('style');\n    s.id = 'iubenda-armani-overrides';\n    s.textContent = css;\n    document.head.appendChild(s);\n  }\n}\n\nfunction centerText() {\n  var banner = document.getElementById('iubenda-cs-banner');\n  if (!banner) return;\n  banner.querySelectorAll('p,.iub-p,[class*=\"content\"],[class*=\"body\"]')\n    .forEach(function(el) { el.style.setProperty('text-align','center','important'); });\n}\n\nvar observer = new MutationObserver(function() {\n  if (document.getElementById('iubenda-cs-banner')) {\n    injectStyles();\n    centerText();\n    setTimeout(centerText, 100);\n    setTimeout(centerText, 500);\n  }\n});\nobserver.observe(document.body, { childList: true, subtree: true });\n\n/* ── 4. Load external scripts in guaranteed order ── */\n\nfunction loadScript(src, onload) {\n  var s = document.createElement('script');\n  s.async = true;\n  s.src = src;\n  if (onload) s.onload = onload;\n  document.head.appendChild(s);\n}\n\nloadScript('https://cdn.iubenda.com/cs/ccpa/stub.js', function() {\n  loadScript('https://cdn.iubenda.com/cs/iubenda_cs.js');\n});\n\n})();"])</script><script>self.__next_f.push([1,"5:[\"$\",\"html\",null,{\"lang\":\"en\",\"dir\":\"ltr\",\"children\":[[\"$\",\"head\",null,{\"children\":[[\"$\",\"$L1e\",null,{\"id\":\"iubenda-init\",\"strategy\":\"afterInteractive\",\"dangerouslySetInnerHTML\":{\"__html\":\"$1f\"}}],\"$L20\",\"$L21\",\"$L22\",\"$L23\",\"$L24\",\"$L25\"]}],\"$L26\"]}]\n20:[[\"$\",\"link\",null,{\"rel\":\"dns-prefetch\",\"href\":\"https://cms.armanihotels.com\"}],[\"$\",\"link\",null,{\"rel\":\"preconnect\",\"href\":\"https://cms.armanihotels.com\",\"crossOrigin\":\"anonymous\"}]]\n21:[\"$\",\"link\",null,{\"rel\":\"dns-prefetch\",\"href\":\"https://static.travelclick.com\"}]\n22:[\"$\",\"link\",null,{\"rel\":\"preconnect\",\"href\":