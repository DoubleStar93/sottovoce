WORLD OF LUXURY\"}],[\"$\",\"p\",null,{\"className\":\"font-body text-lg italic text-primary/70 mb-5\",\"children\":\"Understated elegance, uncompromising attention to detail and stunning views meet world-class services and unmatched culinary offerings, ensuring an unforgettable experience for guests staying at our urban retreat.\\n\\n\"}],null]}]}]}]\n"])</script><script>self.__next_f.push([1,"39:[\"$\",\"$1\",\"782\",{\"children\":[[\"$\",\"section\",null,{\"className\":\"chessboard-square px-4 md:px-[80px] py-10 md:py-0\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-7xl mx-auto\",\"children\":[\"$\",\"div\",null,{\"className\":\"flex flex-col md:flex-row items-center justify-between gap-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-full lg:w-1/2 order-1 lg:order-2\",\"children\":[\"$\",\"div\",null,{\"className\":\"relative w-full aspect-4/3 mx-auto overflow-hidden max-w-[500px] md:max-w-[700px] group/img\",\"children\":[[\"$\",\"$L32\",null,{\"src\":\"https://cms.armanihotels.com/uploads/w768_2e89b12b99.webp\",\"alt\":\"REST IN ULTIMATE STYLE\",\"fill\":true,\"className\":\"object-cover transition-transform duration-700 ease-out group-hover/img:scale-105\",\"sizes\":\"(max-width: 1024px) 100vw, 650px\",\"quality\":90}],[\"$\",\"div\",null,{\"className\":\"absolute inset-0 bg-black/0 group-hover/img:bg-black/10 transition-colors duration-700\"}]]}]}],[\"$\",\"div\",null,{\"className\":\"w-full lg:w-1/2 order-2 lg:order-1 pt-8 lg:pt-0\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-[500px] mx-auto text-center\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-body text-[13px] font-light uppercase tracking-eyebrow text-eyebrow mb-0 block uppercase\",\"children\":\"STAY\"}],[\"$\",\"h2\",null,{\"className\":\"font-display text-[32px] md:text-[56px] md:leading-[56px] mt-4\",\"children\":\"REST IN ULTIMATE STYLE\"}],[\"$\",\"p\",null,{\"className\":\"font-body text-[18px] leading-[32px] text-primary/80 mt-4\",\"dangerouslySetInn