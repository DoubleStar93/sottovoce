#googlemaps{
	z-index:-1
}
.map-left-address-div{
	background:white;
	padding: 45px 50px;
	width: 315px;
	margin-top: 115px;
  margin-left: 15px;
	box-shadow: 0px 0px 30px 0px                  rgba(71,71,71,0.08)
}
.address-div{
	margin-top: 20px;
}


.th-gmap-hoursop p {
    font-size: 14px;
}
.th-gmap-links{
	margin-top:25px;
}
.th-gmap-links a {
	/*
	  font-family: Poppins,             Helvetica,   Arial, sans-         serif;
    font-size: 14px;
    color: #9D9684;
    font-weight: 600;
    text-transform: uppercase;
