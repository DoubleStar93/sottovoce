  var pagination_from_title = '上一页';
  var pagination_to_title = '下一页';
  var mobile_menu_back_button = '';
  var sortby_text = '';
  var languageCode = 'zh_CN';
  var payment_plan_title = 'Payment Plan';
  var payment_plan_milestones = 'Milestones';
  var payment_plan_aed = 'AED';
  var payment_plan_unavailable = 'No payment plan available';
  var waiting_list_button_text = '';
  var view_all_units_button_text = '';
  var loan_duration_years = '';
  var label_principal = '';
  var label_interest = '';
  var label_remaining_balance = '';
  var formHtml = [];
  var custom_client_ID  = 'fa40b66b5282f43ec8be0edf1134f8f1b63e7840cff0256a69c6cb5d9be9cad3';
  var unified_api_call  = '';
  var device = 'desktop';
