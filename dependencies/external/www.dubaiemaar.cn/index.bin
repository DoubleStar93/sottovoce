  function getCookie(name) {
    var dc = document.cookie;
    var prefix = name + "=";
    var begin = dc.indexOf("; " + prefix);
    if (begin == -1) {
      begin = dc.indexOf(prefix);
      if (begin != 0) return null;
    } else {
      begin += 2;
      var end = document.cookie.indexOf(";", begin);
      if (end == -1) {
        end = dc.length;
      }
    }
    return decodeURI(dc.substring(begin + prefix.length, end));
  }

  if (getCookie("custom_client_id")) {
    jQuery.ajax({
      type: "POST",
      url: ct_ajax_script.ajaxurl,
      data: {
        action: 'get_personalization_content'
      },
      success: function(response) {
        response = JSON.parse(response);
        if (response.message == 'success') {
          videoSrc = response.data.video_link;
          $('#input_1_29').val(response.data.community_name);
        }
      },
      error: function(jqXHR, textStatus, errorThrown) {}
    });
  }
  // Akash Optimisation End

	// set event listener to execute on timeupdate. This gets invoked every ~250ms or so
	$('video#v').on('timeupdate',function() {
		var switchVideoSecond = 6;
		var showOverlaySecond = 0;
		var hideOverlaySecond = 0;
		var ct = parseInt(this.currentTime);
		if (this.lastTime!=ct) {
			switch (ct) {
				case switchVideoSecond - 2:
					if( videoChanged == false && videoSrc )
						$('video#v source').attr('src', videoSrc);
				break;
				case switchVideoSecond:
					if( videoChanged == false && videoSrc ){
						$("video#v")[0].load();
						videoChanged = true;
					}
				break;
				/* 18th Second of 2nd Video */
				case showOverlaySecond:
					if( videoChanged )
					{
						if (checkMobile.matches) {
							if($('#prop_search_mobile_form').css('display') == 'none')
							{
								$('#video_overlay').show();
							}
						}
						else{
							$('#video_overlay').show();
						}
					}
						
				break;
				case hideOverlaySecond:
					if( videoChanged )
						$('#video_overlay').hide();
				break;
				case switchVideoSecond - 3:
					if( videoChanged == false )
						$('video#v').attr('poster', '');					
				break;
			}
			$('#currentTime').html( parseInt( $("video#v")[0].currentTime ) );
			var totalDuration = $("video#v")[0].duration;
			$('#totalTime').html( totalDuration );
		}
		this.lastTime=ct;
	});

