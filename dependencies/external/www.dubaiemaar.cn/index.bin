	function searchInStickyFooter(){
    $('html, body').animate({ scrollTop: 100 }, 600);
    $("#btn-show-filters").click();	
    $(".homepage-mobile-filter-section #prop_search_mobile_form").show();
    $("#btn-show-filters").hide();	
