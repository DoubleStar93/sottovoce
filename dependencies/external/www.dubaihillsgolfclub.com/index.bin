			#googlemaps{
	z-index:-1
}
.map-left-address-div{
	background:white;
	padding: 40px 50px;
	width: 315px;
	margin-top: 115px;
  margin-left: 15px;
	box-shadow: 0px 0px 30px 0px                  rgba(71,71,71,0.08)
}
.address-div{
	margin-top: 20px;
}
.map-left-address-div h3{
	font-size:25px;
	font-weight:500;
	color:#3E3E3E;
	font-family: "EB Garamond",       Georgia, serif;
  font-weight: 500;
}

.th-gmap-hoursop p {
    font-size: 14px;
}
.th-gmap-links{
	margin-top:25px;
}
.th-gmap-links a {
    font-size: 14px;
    color: black;
    font-weight: 600;
    text-decoration: none;
    padding-right: 20px;
    margin-top: 5px;
}
.th-gmap-links a:hover {   
    color:teal;
}

#home_banner{
/* 	background: url(https://argolfcdev.wpengine.com/wp-content/uploads/2020/05/Arabian-Ranches-Golf-Club-Golf2-copy-1200x675.jpg); */
background-repeat: no-repeat; 
