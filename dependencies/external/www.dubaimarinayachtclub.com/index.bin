        });
        $(".footeroverlay").click(function() {
            $(".footeroverlay").toggle("d-none");
        });

        var containerEl = document.querySelector('.filter-gallery');

        var mixer = mixitup(containerEl, {
            load: {
                filter: '.frontphoto'
            }
        });
    </script>
