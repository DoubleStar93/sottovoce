<script>
    function updateCarouselControls() {
        const isDesktop = window.innerWidth >= 768; // Adjust breakpoint as necessary
        const desktopCount = 3;
        const mobileCount = 3;

        const showControls = (isDesktop && desktopCount > 1) || (!isDesktop && mobileCount > 1);
        document.getElementById('carouselPrev').classList.toggle('d-none', !showControls);
        document.getElementById('carouselNext').classList.toggle('d-none', !showControls);
    }

    // Initialize controls visibility on page load
    updateCarouselControls();

    // Update controls visibility on window resize
    window.addEventListener('resize', updateCarouselControls);
</script>


