            <script>
              $(document).ready(function() {
                // Function to update the href of the ds-view-all link
                function updateHref(type) {
                  var baseUrl = 'https://www.emaarmalls.ae';
                  var mall = 'the-springs-souk';
                  var newHref = baseUrl + '/' + type + "/?mall=" + mall;
                  $('.ds-view-shop').attr('href', newHref);
                }

                // Listen for tab change events
                $('#shopmyTab a').on('shown.bs.tab', function(e) {
                  var newType = $(e.target).data('type');
                  updateHref(newType);
                });

                // Set the initial href on page load
                var initialType = $('#shopmyTab .nav-link.active').data('type');
                updateHref(initialType);
              });
            </script>
