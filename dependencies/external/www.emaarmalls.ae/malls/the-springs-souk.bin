<section class="internal-banner malls-page" style="background-image: linear-gradient(257deg, rgba(37,40,45,0) 0%, #000000 100%), linear-gradient(300deg, #000000 0%, rgba(37,40,45,0) 50%), url('https://www.emaarmalls.ae/wp-content/uploads/2022/11/TSS_1524x560_1-1.jpg')">
  <div class="container">
    <div class="internal-banner__wrapper">
      <nav class="internal-banner__breadcrumb" style="--bs-breadcrumb-divider: '>';" aria-label="breadcrumb">
