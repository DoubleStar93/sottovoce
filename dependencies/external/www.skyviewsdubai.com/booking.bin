<script type="text/javascript">
var base_url = 'https://www.skyviewsdubai.com';
var ICL_LANGUAGE_CODE = "en";
var page_name = "";
    page_name = "tickets";

var currentTime = new Date();
currentTime = currentTime.getHours()+currentTime.getSeconds();
if(page_name!="tickets" && page_name!="booking"){
    window.sessionStorage.removeItem("sv_session");
    window.sessionStorage.removeItem("timer_started");
}
var session_id = null;

if(window.sessionStorage.getItem("sv_session")!=null && window.sessionStorage.getItem("sv_session")!="undefined"){
    session_id = window.sessionStorage.getItem("sv_session");
            window.location.href = 'https://www.skyviewsdubai.com/booking?sess='+session_id+"&t="+currentTime;
    }

</script>
