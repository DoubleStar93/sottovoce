<div class="booking_content_wrap">
    <div id="ticket_selection" class="booking-step" style="display:block;">
        <div class="container">
            <div class="booking_content_header experiences_content_header">
                <h2>&nbsp;</h2>
                <!-- <div class="close_booking fa fa-times"></div> -->
            </div>
            <div class="booking_content">
            
            <div class="booking_experiences" id="tickets_list">
                    <ul>
                        
                                <li>
                                    <div class="thumbnail" style="background-image:url(https://www.skyviewsdubai.com/wp-content/uploads/2025/07/SVO-Eid-Offer-26_SVO-EID-26-2160-x-1215-scaled.jpg)"></div>
                                    <div class="text">
                                        <h3>Edge Walk</h3>
                                        <div class="ticket_info">
                                            <p>Ready to rise to the challenge? Step onto the city’s highest hands-free walk that encircles the hotel’s exterior and get a bird’s eye view of the city beneath your feet.</p>
<p><strong>AED 299</strong></p>
                                        </div>
                                        <div class="clr"></div>
                                        <div class="select_ticket btn" data-title="Edge Walk" data-id="1809">Select</div>
                                        
                                    </div>
                                </li>
                                
                                <li>
                                    <div class="thumbnail" style="background-image:url(https://www.skyviewsdubai.com/wp-content/uploads/2026/01/EEG-SV-25-019-SVO-Digital-Refresh-January_web-banners_1920x1080px.jpg)"></div>
                                    <div class="text">
                                        <h3>Observatory + Free Slide</h3>
                                        <div class="ticket_info">
                                            <p><span data-olk-copy-source="MessageBody">Ride the panoramic glass elevator 219.5 meters above the ground. Walk the 46-metre glass floor, and enjoy the thrilling Glass Slide.</span></p>
<p><strong>AED 89 (Adult)/AED 69 (Child)</strong></p>
                                        </div>
                                        <div class="clr"></div>
                                        <div class="select_ticket btn" data-title="Observatory + Free Slide" data-id="264">Select</div>
                                        
                                    </div>
                                </li>
                                
                                <li>
                                    <div class="thumbnail" style="background-image:url(https://www.skyviewsdubai.com/wp-content/uploads/2025/05/EEG-CO-25-015-SVO-x-DAUZ-Combo_2160x1215px.jpg)"></div>
                                    <div class="text">
                                        <h3>Dubai Aquarium + Sky Views Combo</h3>
                                        <div class="ticket_info">
                                            <p>Explore the depths and soar to the skies with the Dubai Aquarium + Sky Views Combo.</p>
<p><strong>AED 229</strong></p>
                                        </div>
                                        <div class="clr"></div>
                                        <div class="select_ticket btn" data-title="Dubai Aquarium + Sky Views Combo" data-id="1569">Select</div>
                                        
                                    </div>
                                </li>
                                
                                <li>
                                    <div class="thumbnail" style="background-image:url(https://www.skyviewsdubai.com/wp-content/uploads/2025/04/Gold-Menu-scaled.jpg)"></div>
                                    <div class="text">
                                        <h3>SKY VIEWS + GOLD COLLECTION MENU</h3>
                                        <div class="ticket_info">
                                            <p>Sky-High Luxury: Sky Views Observatory &amp; The Gold Collection Indulgence. Walk on air, slide through the sky, and indulge in exquisite 24K gold-infused delights.</p>
<p><strong>AED 158 (Adult)/AED 128 (Child)</strong></p>
                                        </div>
                                        <div class="clr"></div>
                                        <div class="select_ticket btn" data-title="SKY VIEWS + GOLD COLLECTION MENU" data-id="1467">Select</div>
                                        
                                    </div>
                                </li>
                                
                                <li>
                                    <div class="thumbnail" style="background-image:url(https://www.skyviewsdubai.com/wp-content/uploads/2024/10/EEG-SV-26-003-SVO-Ultimate-Experience_web-banners_800x600px-.jpg)"></div>
                                    <div class="text">
                                        <h3>ULTIMATE EXPERIENCE: OBSERVATORY + SLIDE + CAFÉ + SOUVENIR</h3>
                                        <div class="ticket_info">
                                            <p>Dine, slide &amp; take home a souvenir. Access the Observatory, enjoy the thrilling Glass Walk and Glass slide, savor a snack + drink, and grab a handpicked souvenir.</p>
<p><strong>AED 159 (Adult)/AED 106 (Child)</strong></p>
                                        </div>
                                        <div class="clr"></div>
                                        <div class="select_ticket btn" data-title="ULTIMATE EXPERIENCE: OBSERVATORY + SLIDE + CAFÉ + SOUVENIR" data-id="1221">Select</div>
                                        
                                    </div>
                                </li>
                                
                                <li>
                                    <div class="thumbnail" style="background-image:url(https://www.skyviewsdubai.com/wp-content/uploads/2021/09/skyviews-restaurant-ticket.jpg)"></div>
                                    <div class="text">
                                        <h3>SKY VIEWS + HOTEL LUNCH</h3>
                                        <div class="ticket_info">
                                            <p>Compliment your visit to the Observatory between 12pm-3pm with a delicious 3-course lunch at Adress Sky View.</p>
<p><strong>AED 224 (Adult)/AED 132 (Child)</strong></p>
                                        </div>
                                        <div class="clr"></div>
                                        <div class="select_ticket btn" data-title="SKY VIEWS + HOTEL LUNCH" data-id="914">Select</div>
                                        
                                    </div>
                                </li>
                                
                                <li>
                                    <div class="thumbnail" style="background-image:url(https://www.skyviewsdubai.com/wp-content/uploads/2022/08/Afternoon-Tea-Image-PT-2-1-scaled.jpg)"></div>
                                    <div class="text">
                                        <h3>SKY VIEWS + HOTEL AFTERNOON TEA</h3>
                                        <div class="ticket_info">
                                            <p><span data-olk-copy-source="MessageBody">Compliment your Observatory visit with a signature Afternoon Tea at Address Sky View featuring perfectly handcrafted savoury and sweet treats at The Patisserie every day from 3pm to 7pm. </span></p>
<p><strong>AED 254 (Adult)/AED 147 (Child)</strong></p>
                                        </div>
                                        <div class="clr"></div>
                                        <div class="select_ticket btn" data-title="SKY VIEWS + HOTEL AFTERNOON TEA" data-id="912">Select</div>
                                        
                                    </div>
                                </li>
                                                    </ul>
                </div>
            </div>
        </div>
    </div>
