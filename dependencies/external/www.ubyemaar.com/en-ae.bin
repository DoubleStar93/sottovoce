<script>
	document.addEventListener('DOMContentLoaded', function () {
		const dropdownItems = document.querySelectorAll('.dropdown-item[data-country-filter]');
		const cards = document.querySelectorAll('.homepage-earn-redeem-tab-content-card-main');
		const dropdownButton = document.getElementById('dropdownMenuButton');
		const selectedCountryHeader = document.querySelector('.selected-country-name');

		// Map country to currency
		const countryToCurrencyMap = {
			'uae': 'aed',
			'ksa': 'sar',
			'bahrain': 'bhd'
		};

		// Function to filter cards by country/currency
		function filterCards(selectedCountry) {
			let visibleCardCount = 0;

			cards.forEach(card => {
				const cardCountryRaw = card.getAttribute('data-country');
				const cardCountry = cardCountryRaw ? cardCountryRaw.trim().toLowerCase() : '';

				if (!selectedCountry || selectedCountry === '' || cardCountry === selectedCountry) {
					card.style.setProperty('display', 'flex', 'important');
					visibleCardCount++;
				} else {
					card.style.setProperty('display', 'none', 'important');
				}
			});

			console.log('Visible cards after filter:', visibleCardCount);
		}

		// On Page Load: get country from header, map to currency, update dropdown text and filter cards
		if (selectedCountryHeader) {
			const headerCountry = selectedCountryHeader.textContent.trim().toLowerCase();
			const mappedCurrency = countryToCurrencyMap[headerCountry];

			if (mappedCurrency) {
				dropdownButton.textContent = mappedCurrency.toUpperCase(); // Show currency in uppercase in button
				filterCards(mappedCurrency);
			} else {
				filterCards('');
			}
		}

		dropdownItems.forEach(item => {
			item.addEventListener('click', function (e) {
				e.preventDefault();

				const selectedCountry = this.getAttribute('data-country-filter').trim().toLowerCase();
				const selectedText = this.textContent.trim();

				dropdownButton.textContent = selectedText;

				filterCards(selectedCountry);
			});
		});
	});
</script>


