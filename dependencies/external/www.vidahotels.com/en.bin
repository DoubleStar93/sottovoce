<body>

<li class="nav-item dropdown datepicker-widget dropup p-0">
  <a class="nav-link pr-0 daterangepickerfeild_widget"
     href="javascript:void(0)"
     data-toggle="dropdown"
     aria-haspopup="true"
     aria-expanded="false">

    <div class="date-selector" id="datePickerWrapper">
      <div class="date-top">
        <i class="fal fa-calendar pr-2"></i>
        <span id="" class="text-widget-color">Dates</span>
      </div>

      <div class="date-bottom">
        <input id="datepick_widget_stay"
               class="w-100 datepick-input h-100"
               onkeydown="return false"
               value="Check In - Check Out"
               autocomplete="off"
               readonly>
               <span id="night_var_widget"></span>
      </div>
    </div>

  </a>
</li>

<script>
/* --- added JS --- */
document.addEventListener('DOMContentLoaded', function () {
  const wrapper = document.getElementById('datePickerWrapper');
  const input = document.getElementById('datepick_widget_stay');

  if (!wrapper || !input) return;

  wrapper.addEventListener('click', function (e) {
    e.preventDefault();

    // Bootstrap dropdown open
    const trigger = this.closest('.nav-item')
      .querySelector('.daterangepickerfeild_widget');

    if (trigger) {
      trigger.click();
    }

    // Datepicker trigger
    setTimeout(function () {
      input.focus();
    }, 100);
  });
});
</script>
