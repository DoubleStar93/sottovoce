    $(".ft-dropdown").click(function() {
      $(".ft-menu").slideToggle();
      $(".ft-dropdown i").toggleClass("fa-caret-up fa-caret-down");
      setTimeout(function() {
        $(document).scrollTop($(document).height());
      }, 400);
    });

  });
</script>

</body>

